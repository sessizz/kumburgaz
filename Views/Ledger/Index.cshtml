@model Kumburgaz.Web.Models.LedgerIndexViewModel
@using Kumburgaz.Web.Services
@{
    ViewData["Title"] = "Giderler";
    var exportUrl = Url.Action("ExportCsv", "Ledger", new
    {
        startDate = Model.StartDate?.ToString("yyyy-MM-dd"),
        endDate = Model.EndDate?.ToString("yyyy-MM-dd")
    }) ?? "#";

    if (Model.CategoryIds.Count > 0)
    {
        var categoryQuery = string.Join("&", Model.CategoryIds.Select(id => $"categoryIds={id}"));
        exportUrl = $"{exportUrl}{(exportUrl.Contains('?') ? "&" : "?")}{categoryQuery}";
    }

    string CategoryBadgeClass(int? categoryId) => $"badge ledger-category-badge ledger-category-{Math.Abs(categoryId.GetValueOrDefault()) % 12}";
}

<div class="space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-2xl font-extrabold">Giderler</h2>
            <p class="text-sm text-gray-400">Aidat dışı gelir/gider hareketleri</p>
        </div>
        <div class="flex gap-2">
            <a class="btn btn-outline btn-sm" href="@exportUrl">
                <span class="material-symbols-outlined ms-sm">download</span>
                CSV
            </a>
            <a class="btn btn-primary btn-sm" asp-action="Create">
                <span class="material-symbols-outlined ms-sm">add</span>
                Yeni Gider
            </a>
        </div>
    </div>

    @if (TempData["ImportSuccess"] is string successMessage)
    {
        <div class="alert alert-success">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@successMessage</span>
        </div>
    }
    @if (TempData["ImportError"] is string errorMessage)
    {
        <div class="alert alert-error">
            <span class="material-symbols-outlined">error</span>
            <span>@errorMessage</span>
        </div>
    }
    @if (TempData["ActionSuccess"] is string actionSuccess)
    {
        <div class="alert alert-success">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@actionSuccess</span>
        </div>
    }
    @if (TempData["ActionError"] is string actionError)
    {
        <div class="alert alert-error">
            <span class="material-symbols-outlined">error</span>
            <span>@actionError</span>
        </div>
    }

    <form method="get" class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
            <fieldset class="fieldset md:col-span-2">
                <legend class="fieldset-legend">Gider kategorileri</legend>
                <div class="rounded-lg border border-gray-300 max-h-36 overflow-y-auto p-2">
                    @foreach (var option in Model.CategoryOptions)
                    {
                        <label class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-gray-50">
                            <input type="checkbox" name="categoryIds" value="@option.Value" checked="@option.Selected" class="checkbox checkbox-sm" />
                            <span>@option.Text</span>
                        </label>
                    }
                </div>
            </fieldset>
            <fieldset class="fieldset">
                <legend class="fieldset-legend">Başlangıç</legend>
                <input type="date" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" class="input input-bordered w-full" />
            </fieldset>
            <fieldset class="fieldset">
                <legend class="fieldset-legend">Bitiş</legend>
                <input type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" class="input input-bordered w-full" />
            </fieldset>
            <div class="flex gap-2">
                <button class="btn btn-primary flex-1" type="submit">
                    <span class="material-symbols-outlined ms-sm">filter_alt</span>
                    Filtrele
                </button>
                <a class="btn btn-ghost" asp-action="Index">Temizle</a>
            </div>
        </div>
    </form>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="p-6">
            <h3 class="text-sm font-semibold text-gray-700">CSV ile Toplu Yükle</h3>
            <form asp-action="ImportCsv" method="post" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3 items-end">
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Gider CSV dosyası</legend>
                    <input type="file" name="file" accept=".csv,text/csv" class="file-input file-input-bordered w-full" />
                    <p class="label text-xs">Kolonlar: GiderKategoriId, Tarih, Tutar, OdemeKanali veya Hesap, Aciklama</p>
                </fieldset>
                <button type="submit" class="btn btn-outline btn-primary">
                    <span class="material-symbols-outlined ms-sm">upload</span>
                    CSV ile Ekle
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Kategori</th>
                        <th class="text-end">Tutar</th>
                        <th>Kasa / Banka</th>
                        <th>Açıklama</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.Date.ToString("dd.MM.yyyy")</td>
                        <td><span class="@CategoryBadgeClass(row.IncomeExpenseCategoryId)">@row.IncomeExpenseCategory?.Name</span></td>
                        <td class="text-end font-bold">@row.Amount.ToString("N2")</td>
                        <td>
                            <span class="badge badge-ghost">
                                @(row.CashBox?.Name ?? row.BankAccount?.Name ?? EnumDisplayHelper.Display(row.PaymentChannel))
                            </span>
                        </td>
                        <td class="text-sm text-gray-500">@row.Description</td>
                        <td>
                            <div class="flex justify-end gap-1">
                                <a class="btn btn-xs btn-ghost" asp-action="Edit" asp-route-id="@row.Id">
                                    <span class="material-symbols-outlined ms-sm">edit</span>
                                </a>
                                <form asp-action="Delete" asp-route-id="@row.Id" method="post"
                                      onsubmit="return confirm('Bu gider silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-xs btn-ghost text-error" type="submit">
                                        <span class="material-symbols-outlined ms-sm">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-sm text-gray-500 py-8">Filtreye uygun gider bulunamadı.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-200">
            <h3 class="text-base font-extrabold text-gray-900">İcmal</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Toplam Gider</div>
                <div class="mt-2 text-2xl font-extrabold text-error tabular-nums">@Model.TotalAmount.ToString("N2") TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Kasa Gideri</div>
                <div class="mt-2 text-2xl font-extrabold text-gray-900 tabular-nums">@Model.CashAmount.ToString("N2") TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Banka Gideri</div>
                <div class="mt-2 text-2xl font-extrabold text-gray-900 tabular-nums">@Model.BankAmount.ToString("N2") TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Kayıt Sayısı</div>
                <div class="mt-2 text-2xl font-extrabold text-gray-900 tabular-nums">@Model.Rows.Count</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Ortalama Gider</div>
                <div class="mt-2 text-2xl font-extrabold text-gray-900 tabular-nums">@Model.AverageAmount.ToString("N2") TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">En Yüksek Gider</div>
                <div class="mt-2 text-2xl font-extrabold text-gray-900 tabular-nums">@Model.MaxAmount.ToString("N2") TL</div>
            </div>
        </div>
        @if (Model.CategorySummaryRows.Count > 0)
        {
            <div class="border-t border-gray-100 overflow-x-auto">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Kategori</th>
                            <th class="text-end">Kayıt</th>
                            <th class="text-end">Toplam</th>
                            <th class="text-end">Pay</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.CategorySummaryRows)
                    {
                        var share = Model.TotalAmount == 0 ? 0 : row.TotalAmount / Model.TotalAmount * 100;
                        <tr>
                            <td><span class="@CategoryBadgeClass(row.CategoryId)">@row.CategoryName</span></td>
                            <td class="text-end tabular-nums">@row.Count</td>
                            <td class="text-end font-bold tabular-nums">@row.TotalAmount.ToString("N2") TL</td>
                            <td class="text-end tabular-nums">@share.ToString("N1")%</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
