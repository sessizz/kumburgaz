@model List<Kumburgaz.Web.Models.BillingGroup>
@{
    ViewData["Title"] = "Aidatlandırma Grupları";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Aidatlandırma Grupları</h2>
    <a class="btn btn-primary" asp-action="Create">Yeni Grup</a>
</div>

@if (TempData["ActionSuccess"] is string actionSuccess)
{
    <div class="alert alert-success">@actionSuccess</div>
}
@if (TempData["ActionError"] is string actionError)
{
    <div class="alert alert-danger">@actionError</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Grup</th>
            <th>Aidat Tipi</th>
            <th>Geçerlilik</th>
            <th>Daire / Birleşik Daire</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.DuesType?.Name (@item.DuesType?.Amount.ToString("N2") TL)</td>
            <td>@item.EffectiveStartPeriod - @(item.EffectiveEndPeriod ?? "Devam")</td>
            <td>@BillingGroupDisplayHelper.UnitDisplay(item)</td>
            <td class="d-flex gap-1">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                      onsubmit="return confirm('Bu aidat grubu silinsin mi?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

