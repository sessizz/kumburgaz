@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="max-w-2xl mx-auto">
    <div class="alert alert-error">
        <span class="material-symbols-outlined ms-lg">error</span>
        <div>
            <h3 class="font-bold">Bir hata oluştu</h3>
            <div class="text-sm">İsteğiniz işlenirken bir sorun yaşandı.</div>
        </div>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="mt-4 card bg-base-100 border border-base-300">
            <div class="card-body">
                <p class="text-sm">
                    <span class="font-semibold">İstek ID:</span>
                    <code class="text-xs bg-base-200 px-2 py-1 rounded">@Model.RequestId</code>
                </p>
            </div>
        </div>
    }

    <div class="mt-4 card bg-base-100 border border-base-300">
        <div class="card-body">
            <h3 class="card-title text-base">Geliştirme Modu</h3>
            <p class="text-sm text-base-content/70">
                <strong>Development</strong> ortamına geçerek hata hakkında daha ayrıntılı bilgi görüntüleyebilirsiniz.
            </p>
            <p class="text-sm text-base-content/70">
                <strong>Geliştirme ortamı yayınlanmış uygulamalarda etkinleştirilmemelidir.</strong>
                Hassas bilgileri son kullanıcılara ifşa edebilir. Yerel hata ayıklama için
                <code class="text-xs bg-base-200 px-2 py-1 rounded">ASPNETCORE_ENVIRONMENT=Development</code>
                ortam değişkenini ayarlayıp uygulamayı yeniden başlatın.
            </p>
        </div>
    </div>
</div>
