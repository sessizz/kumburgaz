<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kumburgaz Yönetim</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />

    <style type="text/tailwindcss">
        @@theme {
            --font-sans: "Inter", system-ui, sans-serif;
            --color-primary: #0e7c86;
            --color-primary-content: #ffffff;
            --color-blue-50: #eef6f7;
            --color-blue-100: #dbeef0;
            --color-blue-200: #bfe0e2;
            --color-blue-300: #94cbcf;
            --color-blue-400: #57adb3;
            --color-blue-500: #1f8f97;
            --color-blue-600: #0e7c86;
            --color-blue-700: #0a5c64;
            --color-blue-800: #0a4a51;
            --color-blue-900: #0b3d43;
            --color-blue-950: #062327;
        }
    </style>
    <style>
        :root, html[data-theme="light"] {
            --color-primary: #0e7c86 !important;
            --color-primary-content: #ffffff !important;
        }
        * { font-family: "Inter", system-ui, sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 22;
            vertical-align: middle;
            font-size: 20px;
            line-height: 1;
        }
    </style>
</head>
<body style="background:#f3f4f6; min-height:100vh; display:flex; align-items:center; justify-content:center;">
    <div style="width:100%; max-width:420px; padding:16px;">
        <div class="text-center mb-6">
            <div class="inline-flex items-center gap-2 mb-1">
                <span class="material-symbols-outlined text-blue-600" style="font-size:28px;">apartment</span>
                <span class="text-2xl font-bold text-gray-900 tracking-tight">kumburgaz</span>
            </div>
            <p class="text-sm text-gray-400">Site Yönetim Sistemi</p>
        </div>
        @RenderBody()
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
