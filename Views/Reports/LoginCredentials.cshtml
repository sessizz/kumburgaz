@model List<Kumburgaz.Web.Models.ResidentCredentialRow>
@{
    ViewData["Title"] = "Kullanıcı Giriş Bilgileri";
}

<div class="space-y-4">
    <div class="flex items-center justify-between gap-3 flex-wrap">
        <div class="flex items-center gap-3">
            <a class="btn btn-ghost btn-sm btn-square" asp-action="Index" title="Geri">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="text-2xl font-extrabold">Kullanıcı Giriş Bilgileri</h2>
                <p class="text-sm text-gray-500">Malik/kiracı hesaplarının mobil giriş bilgileri. Kullanıcı adı = hesap numarası.</p>
            </div>
        </div>
        <a class="btn btn-outline btn-sm" asp-action="LoginCredentialsExcel">
            <span class="material-symbols-outlined text-[18px]">download</span> Excel
        </a>
    </div>

    <div class="alert alert-warning text-sm py-2">
        Şifreler bu sayfada açık gösterilir. Yalnızca sistem yöneticisi görebilir; ekranı paylaşırken dikkatli olun.
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 overflow-x-auto">
        <table class="table">
            <thead>
                <tr>
                    <th>Hesap</th>
                    <th>Tür</th>
                    <th>Telefon</th>
                    <th>Daireler</th>
                    <th>Kullanıcı Adı</th>
                    <th>Şifre</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="6" class="text-center text-gray-400 py-6">Malik/kiracı hesabı bulunamadı.</td></tr>
                }
                else
                {
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td class="font-semibold">@row.AccountName</td>
                            <td>@row.AccountTypeLabel</td>
                            <td>@(row.Phone ?? "—")</td>
                            <td class="text-sm text-gray-600">@(string.IsNullOrEmpty(row.Units) ? "—" : row.Units)</td>
                            <td class="font-mono font-bold">@row.UserName</td>
                            <td>
                                @if (row.HasLogin && !string.IsNullOrEmpty(row.Password))
                                {
                                    <span class="font-mono font-bold">@row.Password</span>
                                }
                                else
                                {
                                    <span class="badge badge-ghost">Giriş yok</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
