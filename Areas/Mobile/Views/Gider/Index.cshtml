@model List<MobileGiderListItem>
@{
    ViewData["Title"] = "Gider";
    var isResident = (bool)(ViewBag.IsResident ?? false);
    string Tl(decimal v) => v.ToString("N2") + " TL";
}

@if (TempData["MobileSuccess"] is string ok)
{
    <div class="m-note" style="background:#ecfdf5;border-color:#a7f3d0;color:#047857;">@ok</div>
}
@if (TempData["MobileError"] is string err)
{
    <div class="m-note">@err</div>
}

<a asp-area="Mobile" asp-controller="Gider" asp-action="Yeni"
   style="display:flex;align-items:center;justify-content:center;gap:8px;height:46px;background:var(--m-primary);color:#fff;border-radius:12px;font-weight:700;text-decoration:none;margin-bottom:14px;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
    @(isResident ? "Mahsuplu Gider Ekle" : "Yeni Gider")
</a>

@if (Model.Count == 0)
{
    <div class="m-empty">
        <div class="m-empty-icon">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" /><path d="M3 10h18" /></svg>
        </div>
        <div>Gider kaydı yok.</div>
    </div>
}
else
{
    <div class="m-list">
        @foreach (var g in Model)
        {
            <a class="m-list-item" style="align-items:flex-start;" asp-area="Mobile" asp-controller="Gider" asp-action="Detay" asp-route-id="@g.Id">
                <div class="m-li-main">
                    <div class="m-li-title">@g.CategoryName</div>
                    <div class="m-li-sub" style="white-space:normal;">
                        @g.Date.ToString("dd.MM.yyyy")
                        @if (!string.IsNullOrEmpty(g.UnitDisplay))
                        {
                            <text> · @g.UnitDisplay</text>
                        }
                        @if (!string.IsNullOrWhiteSpace(g.Description))
                        {
                            <text> · @g.Description</text>
                        }
                    </div>
                    <div style="display:flex; gap:6px; margin-top:6px; align-items:center;">
                        @if (g.HasAttachment && g.AttachmentId.HasValue)
                        {
                            <span style="display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:700;color:var(--m-primary);"
                                  onclick="event.preventDefault(); event.stopPropagation(); openLightbox('@Url.Action("Ek", "Gider", new { area = "Mobile", id = g.AttachmentId })')">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a5 5 0 0 1-7.07-7.07l9.19-9.19a3.5 3.5 0 0 1 4.95 4.95l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" /></svg>
                                Fiş
                            </span>
                        }
                        @if (g.IsMahsup)
                        {
                            <span style="font-size:11px;font-weight:700;color:var(--m-primary);background:#eff6ff;padding:2px 8px;border-radius:999px;">Mahsup</span>
                        }
                    </div>
                </div>
                <div style="text-align:right;flex:none;">
                    <div class="m-row-amt m-amt-debt">@Tl(g.Amount)</div>
                </div>
                <span class="m-li-chev">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6" /></svg>
                </span>
            </a>
        }
    </div>
}
