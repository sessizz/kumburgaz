@model Kumburgaz.Web.Models.CashBankDetailViewModel
@using System.Globalization
@{
    var q = Model.Query;
    var actionName = Model.Kind == "bank" ? "BankDetail" : "CashBoxDetail";
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / q.PageSize);
    var rows = Model.Groups.SelectMany(g => g.Items).ToList();
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <form method="get" id="filterForm">
        <div class="flex flex-col lg:flex-row lg:items-center gap-3 px-5 py-3 border-b border-gray-200">
            <div class="flex items-center gap-1 flex-wrap">
                @{
                    var tabs = new[] {
                        ("all", "Tümü", Model.TotalCount),
                        ("tahsilat", "Tahsilat", Model.TahsilatCount),
                        ("cikis", "Para Çıkışı", Model.CikisCount),
                        ("transfer", "Transfer", Model.TransferCount)
                    };
                }
                @foreach (var (val, label, cnt) in tabs)
                {
                    var active = (q.Type ?? "all") == val;
                    <a class="seg-tab @(active ? "active" : "")"
                       href="?type=@val&range=@(q.Range ?? "all")&q=@q.Q&page=1">
                        @label <span class="text-gray-400 ml-1">@cnt</span>
                    </a>
                }
            </div>
            <div class="flex-1"></div>
            <div class="flex items-center gap-2 flex-wrap">
                <label class="input input-bordered input-sm flex items-center gap-2 w-56">
                    <span class="material-symbols-outlined ms-sm text-gray-400">search</span>
                    <input name="q" value="@q.Q" placeholder="Açıklama veya hesap ara" class="grow" />
                </label>
                <input type="hidden" name="type" value="@(q.Type ?? "all")" />
                <select name="range" class="select select-bordered select-sm w-44" onchange="this.form.submit()">
                    <option value="all" selected="@((q.Range ?? "all") == "all")">Tüm tarihler</option>
                    <option value="this_month" selected="@(q.Range == "this_month")">Bu ay</option>
                    <option value="last_month" selected="@(q.Range == "last_month")">Geçen ay</option>
                    <option value="last_90" selected="@(q.Range == "last_90")">Son 90 gün</option>
                </select>
                <a class="btn btn-sm btn-outline"
                   href="?type=@(q.Type ?? "all")&range=@(q.Range ?? "all")&q=@q.Q&export=csv">
                    <span class="material-symbols-outlined ms-sm">download</span>
                    Dışa aktar
                </a>
            </div>
        </div>
    </form>

    @if (!rows.Any())
    {
        <div class="px-5 py-10 text-center text-gray-400 text-sm">İşlem bulunamadı.</div>
    }
    else
    {
        <div class="hidden md:grid grid-cols-[100px_140px_minmax(0,1fr)_160px_160px_40px] gap-3 px-5 py-2 text-[11px] font-semibold tracking-widest uppercase text-gray-400 border-b border-gray-100">
            <div>Tarih</div>
            <div>Tip</div>
            <div>Açıklama</div>
            <div class="text-right">Tutar</div>
            <div class="text-right">Bakiye</div>
            <div></div>
        </div>

        <ul class="divide-y divide-gray-100">
            @foreach (var row in rows)
            {
                <partial name="_DetailParts/_TxRow" model="row" />
            }
        </ul>
    }

    <div class="flex items-center justify-between px-5 py-3 border-t border-gray-200 bg-gray-50/50">
        <span class="text-sm text-gray-500">
            @Model.TotalCount işlem ·
            @(((q.Page - 1) * q.PageSize) + 1)-@(Math.Min(q.Page * q.PageSize, Model.TotalCount)) gösteriliyor
        </span>
        @if (totalPages > 1)
        {
            <div class="flex items-center gap-1">
                @if (q.Page > 1)
                {
                    <a class="btn btn-sm btn-ghost" href="?type=@(q.Type ?? "all")&range=@(q.Range ?? "all")&q=@q.Q&page=@(q.Page - 1)">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                }
                else
                {
                    <button class="btn btn-sm btn-ghost" disabled><span class="material-symbols-outlined">chevron_left</span></button>
                }
                @for (int p = 1; p <= Math.Min(totalPages, 5); p++)
                {
                    if (p == q.Page)
                    {
                        <button class="btn btn-sm btn-primary">@p</button>
                    }
                    else
                    {
                        <a class="btn btn-sm btn-ghost" href="?type=@(q.Type ?? "all")&range=@(q.Range ?? "all")&q=@q.Q&page=@p">@p</a>
                    }
                }
                @if (q.Page < totalPages)
                {
                    <a class="btn btn-sm btn-ghost" href="?type=@(q.Type ?? "all")&range=@(q.Range ?? "all")&q=@q.Q&page=@(q.Page + 1)">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                }
            </div>
        }
    </div>
</div>
