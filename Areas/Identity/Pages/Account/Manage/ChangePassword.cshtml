@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-gray-700">Ana Sayfa</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Hesabımı Yönet</span>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Şifre Değiştir</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6">
        <partial name="_ManageNav" />

        <div class="space-y-6">
            <partial name="_StatusMessage" model="Model.StatusMessage" />

            <div class="bg-white border border-gray-200 rounded-xl p-6">
                <div class="mb-6">
                    <h1 class="text-lg font-semibold text-gray-900">Şifre Değiştir</h1>
                    <p class="text-sm text-gray-500 mt-0.5">Hesabınızın güvenliği için güçlü bir şifre kullanın</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

                    <div class="space-y-5">
                        <div class="form-control">
                            <label asp-for="Input.OldPassword" class="label">
                                <span class="label-text font-medium text-gray-700">Mevcut Şifre</span>
                            </label>
                            <input asp-for="Input.OldPassword" type="password" class="input input-bordered w-full"
                                   autocomplete="current-password" />
                            <span asp-validation-for="Input.OldPassword" class="label-text-alt text-red-500 mt-1 block"></span>
                        </div>

                        <div class="form-control">
                            <label asp-for="Input.NewPassword" class="label">
                                <span class="label-text font-medium text-gray-700">Yeni Şifre</span>
                            </label>
                            <input asp-for="Input.NewPassword" type="password" id="newPassword"
                                   class="input input-bordered w-full" autocomplete="new-password" />
                            <span asp-validation-for="Input.NewPassword" class="label-text-alt text-red-500 mt-1 block"></span>
                        </div>

                        @* Strength meter *@
                        <div>
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-xs text-gray-500">Şifre gücü</span>
                                <span id="strengthLabel" class="text-xs font-medium text-gray-400">—</span>
                            </div>
                            <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                <div id="strengthBar" class="h-full rounded-full transition-all duration-300" style="width:0%;background:#10b981"></div>
                            </div>
                        </div>

                        @* Checklist *@
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
                            <div id="check-length" class="flex items-center gap-2 text-gray-400">
                                <span class="material-symbols-outlined" style="font-size:16px">radio_button_unchecked</span>
                                En az 6 karakter
                            </div>
                            <div id="check-case" class="flex items-center gap-2 text-gray-400">
                                <span class="material-symbols-outlined" style="font-size:16px">radio_button_unchecked</span>
                                Büyük &amp; küçük harf
                            </div>
                            <div id="check-digit" class="flex items-center gap-2 text-gray-400">
                                <span class="material-symbols-outlined" style="font-size:16px">radio_button_unchecked</span>
                                Bir rakam
                            </div>
                        </div>

                        <div class="form-control">
                            <label asp-for="Input.ConfirmPassword" class="label">
                                <span class="label-text font-medium text-gray-700">Yeni Şifre Tekrar</span>
                            </label>
                            <input asp-for="Input.ConfirmPassword" type="password" class="input input-bordered w-full"
                                   autocomplete="new-password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="label-text-alt text-red-500 mt-1 block"></span>
                        </div>
                    </div>

                    <div class="flex justify-end mt-6">
                        <button type="submit" class="btn btn-primary gap-2">
                            <span class="material-symbols-outlined" style="font-size:18px">key</span>
                            Şifreyi Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const pwInput = document.getElementById('newPassword');
        const bar = document.getElementById('strengthBar');
        const label = document.getElementById('strengthLabel');

        function updateCheck(id, ok) {
            const el = document.getElementById(id);
            const icon = el.querySelector('.material-symbols-outlined');
            if (ok) {
                el.classList.replace('text-gray-400', 'text-emerald-600');
                icon.textContent = 'check_circle';
            } else {
                el.classList.replace('text-emerald-600', 'text-gray-400');
                icon.textContent = 'radio_button_unchecked';
            }
        }

        pwInput.addEventListener('input', function () {
            const v = pwInput.value;
            const hasLength = v.length >= 6;
            const hasUpper = /[A-Z]/.test(v);
            const hasLower = /[a-z]/.test(v);
            const hasDigit = /[0-9]/.test(v);
            const hasCase = hasUpper && hasLower;

            updateCheck('check-length', hasLength);
            updateCheck('check-case', hasCase);
            updateCheck('check-digit', hasDigit);

            const score = [hasLength, hasCase, hasDigit, v.length >= 10].filter(Boolean).length;
            const pct = score * 25;
            const colors = ['#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
            const labels = ['Çok Zayıf', 'Zayıf', 'Orta', 'Güçlü'];
            bar.style.width = pct + '%';
            bar.style.background = colors[score - 1] || '#e5e7eb';
            label.textContent = v.length ? (labels[score - 1] || '') : '—';
        });
    </script>
}
