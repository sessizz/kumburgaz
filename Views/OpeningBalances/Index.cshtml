@model List<Kumburgaz.Web.Models.Unit>
@{
    ViewData["Title"] = "Devir Bakiyeleri";
    var blocks = ViewBag.Blocks as List<Kumburgaz.Web.Models.Block> ?? new List<Kumburgaz.Web.Models.Block>();
    var selectedBlockId = ViewBag.SelectedBlockId as int?;
    var totalCredit = Model.Where(x => x.OpeningBalance > 0).Sum(x => x.OpeningBalance);
    var totalDebt = Model.Where(x => x.OpeningBalance < 0).Sum(x => -x.OpeningBalance);
    var net = Model.Sum(x => x.OpeningBalance);
}

<div class="space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-2xl font-extrabold">Devir Bakiyeleri</h2>
            <p class="text-sm text-gray-400">Önceki yönetimden devreden alacak / borç bakiyeleri</p>
        </div>
    </div>

    @if (TempData["ActionSuccess"] is string actionSuccess)
    {
        <div class="alert alert-success">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@actionSuccess</span>
        </div>
    }
    @if (TempData["ActionError"] is string actionError)
    {
        <div class="alert alert-error">
            <span class="material-symbols-outlined">error</span>
            <span>@actionError</span>
        </div>
    }

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="p-4 border-b border-gray-200 flex flex-wrap items-center gap-3 justify-between">
            <form method="get" class="flex items-center gap-2">
                <label class="text-sm text-gray-600">Blok:</label>
                <select name="blockId" class="select select-bordered select-sm" onchange="this.form.submit()">
                    <option value="">Tümü</option>
                    @foreach (var b in blocks)
                    {
                        if (selectedBlockId == b.Id)
                        {
                            <option value="@b.Id" selected>@b.Name</option>
                        }
                        else
                        {
                            <option value="@b.Id">@b.Name</option>
                        }
                    }
                </select>
            </form>
            <div class="flex items-center gap-4 text-sm">
                <span class="text-gray-500">Toplam Alacak:</span>
                <span class="font-bold text-green-600">@totalCredit.ToString("N2") TL</span>
                <span class="text-gray-300">|</span>
                <span class="text-gray-500">Toplam Borç:</span>
                <span class="font-bold text-red-600">@totalDebt.ToString("N2") TL</span>
                <span class="text-gray-300">|</span>
                <span class="text-gray-500">Net:</span>
                <span class="font-bold @(net >= 0 ? "text-green-600" : "text-red-600")">@net.ToString("N2") TL</span>
            </div>
        </div>

        <form asp-action="Save" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="blockId" value="@selectedBlockId" />

            <div class="overflow-x-auto">
                <table class="table table-zebra">
                    <thead>
                        <tr>
                            <th class="w-24">Blok</th>
                            <th class="w-24">Daire No</th>
                            <th>Malik</th>
                            <th class="w-64 text-end">Devir Bakiyesi (TL)</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="font-semibold">@item.Block?.Name</td>
                            <td>@item.UnitNo</td>
                            <td class="text-sm">@item.OwnerName</td>
                            <td>
                                <input type="hidden" name="unitIds" value="@item.Id" />
                                <input type="text"
                                       name="balances"
                                       value="@(item.OpeningBalance == 0 ? "" : item.OpeningBalance.ToString("0.##", System.Globalization.CultureInfo.GetCultureInfo("tr-TR")))"
                                       class="input input-bordered input-sm w-full text-end"
                                       placeholder="0,00"
                                       inputmode="decimal" />
                            </td>
                        </tr>
                    }
                    @if (Model.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-gray-400 py-6">Daire bulunamadı.</td></tr>
                    }
                    </tbody>
                </table>
            </div>

            <div class="p-4 border-t border-gray-200 bg-gray-50 flex justify-between items-center">
                <p class="text-xs text-gray-500">
                    <span class="font-semibold">Pozitif</span> = daire alacaklı (gelecek aidatlardan düşülür) ·
                    <span class="font-semibold">Negatif</span> = daire borçlu (devreden borç olarak eklenir)
                </p>
                <button type="submit" class="btn btn-primary btn-sm">
                    <span class="material-symbols-outlined ms-sm">save</span>
                    Tümünü Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
