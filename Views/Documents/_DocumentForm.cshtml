@model Kumburgaz.Web.Models.DocumentRecord
@{
    var isEdit = Model.Id > 0;
}
<div class="max-w-3xl">
    <form method="post" enctype="multipart/form-data" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="flex items-center justify-between"><h1 class="text-2xl font-extrabold text-gray-900">@(isEdit ? "Belge Düzenle" : "Yeni Belge")</h1><a class="btn btn-ghost btn-sm" asp-action="Index">Geri</a></div>
        <div asp-validation-summary="ModelOnly" class="text-error text-sm"></div>
        <fieldset class="fieldset"><legend class="fieldset-legend">Başlık</legend><input asp-for="Title" class="input input-bordered w-full" /></fieldset>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <fieldset class="fieldset"><legend class="fieldset-legend">Kategori</legend><input asp-for="Category" class="input input-bordered w-full" /></fieldset>
            <fieldset class="fieldset"><legend class="fieldset-legend">Belge Tarihi</legend><input asp-for="DocumentDate" type="date" class="input input-bordered w-full" /></fieldset>
        </div>
        <fieldset class="fieldset">
            <legend class="fieldset-legend">Dosyalar</legend>
            <input type="file" name="files" multiple
                   accept=".pdf,.jpg,.jpeg,.png,.webp,.gif,.docx,.xlsx,.xls,.csv,.txt"
                   class="file-input file-input-bordered w-full" />
            <div class="text-xs text-gray-500 mt-2">Birden fazla dosya seçebilirsiniz. Her dosya en fazla 25 MB olabilir.</div>
            <div class="mt-2">
                <partial name="_PhoneCapturePanel" model="@("belge")" />
            </div>
        </fieldset>
        <fieldset class="fieldset"><legend class="fieldset-legend">Not</legend><textarea asp-for="Note" class="textarea textarea-bordered w-full min-h-28"></textarea></fieldset>
        <div class="flex justify-end gap-2"><a class="btn btn-ghost" asp-action="Index">Vazgeç</a><button class="btn btn-primary"><span class="material-symbols-outlined ms-sm">save</span>Kaydet</button></div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/phone-capture.js" asp-append-version="true"></script>
}
