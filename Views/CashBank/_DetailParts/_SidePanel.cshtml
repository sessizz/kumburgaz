<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="flex border-b border-gray-200 px-2 pt-2 gap-1">
        <button class="seg-tab" onclick="switchTab(this,'notes')" data-tab="notes">Notlar</button>
        <button class="seg-tab active" onclick="switchTab(this,'history')" data-tab="history">Geçmiş</button>
    </div>

    <div id="panel-history" class="p-4">
        @if (Model.History.Any())
        {
            <ul class="space-y-1">
                @foreach (var h in Model.History)
                {
                    <li class="tl-item @h.Action">
                        <span class="tl-dot"></span>
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined @(h.Action == "created" ? "text-emerald-500" : "text-blue-500")" style="font-size:18px;">
                                @(h.Action == "created" ? "add_circle" : "edit_note")
                            </span>
                            <span class="text-sm font-semibold text-gray-900">@h.Title</span>
                        </div>
                        <div class="text-xs text-gray-500 mt-0.5 ml-6">
                            @h.At.ToString("dd.MM.yyyy HH:mm") · <span class="text-gray-700 font-medium">@h.ByUserName</span>
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-sm text-gray-400">Geçmiş yok.</p>
        }
    </div>

    <div id="panel-notes" class="p-4 hidden">
        <textarea class="textarea textarea-bordered w-full text-sm" rows="4" placeholder="Bu hesapla ilgili notlarınız…">@Model.Note</textarea>
        <div class="flex justify-end mt-2">
            <button class="btn btn-sm btn-primary">Kaydet</button>
        </div>
    </div>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold tracking-widest uppercase text-gray-400 mb-3">Hızlı Bakış</div>
    <div class="space-y-2.5 text-sm">
        <div class="flex items-center justify-between">
            <span class="text-gray-500">Açılış bakiyesi</span>
            <span class="font-semibold text-gray-900 tabular-nums">@Model.OpeningBalance.ToString("N2", trTR) ₺</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-gray-500">Açılış tarihi</span>
            <span class="font-semibold text-gray-900">@Model.OpeningDate.ToString("dd.MM.yyyy")</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-gray-500">Toplam işlem</span>
            <span class="font-semibold text-gray-900">@Model.TotalCount</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-gray-500">Bekleyen</span>
            <span class="font-semibold @(Model.PendingCount > 0 ? "text-amber-600" : "text-gray-900")">@Model.PendingCount</span>
        </div>
    </div>
</div>

<script>
function switchTab(btn, tab) {
    document.querySelectorAll('.seg-tab[data-tab]').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    ['notes','history'].forEach(id => {
        var el = document.getElementById('panel-' + id);
        if (el) el.classList.toggle('hidden', id !== tab);
    });
}

function syncIncomeFields() {
    var modal = document.getElementById('incomeModal');
    if (!modal) return;

    var source = modal.querySelector('[data-income-source]');
    var isDues = source && source.value === 'dues';
    var isLedger = source && source.value.startsWith('category:');

    modal.querySelectorAll('[data-income-dues-fields]').forEach(function(element) {
        element.classList.toggle('hidden', !isDues);
    });
    modal.querySelectorAll('[data-income-ledger-fields]').forEach(function(element) {
        element.classList.toggle('hidden', !isLedger);
    });
    modal.querySelectorAll('[data-income-dues-fields] input, [data-income-dues-fields] select, [data-income-dues-fields] textarea').forEach(function(element) {
        element.disabled = !isDues;
    });

    var duesSelect = modal.querySelector('[data-dues-select]');
    if (duesSelect) duesSelect.required = isDues;

    var receiptCheckbox = modal.querySelector('#createCollectionIsReceipt');
    var referenceNo = modal.querySelector('#createCollectionReferenceNo');
    if (referenceNo && receiptCheckbox) referenceNo.required = isDues && receiptCheckbox.checked;
}

function openLedgerModal(isBankFee) {
    document.getElementById('ledgerIsBankFee').value = isBankFee ? 'true' : 'false';
    document.getElementById('ledgerModalTitle').textContent = isBankFee ? 'Banka Masrafı' : 'Ödeme';
    document.getElementById('ledgerDescription').placeholder = isBankFee ? 'Banka masrafı açıklaması' : 'Ödeme açıklaması';
    ledgerModal.showModal();
}

function normalizeDuesSearch(value) {
    return (value || '').toLocaleLowerCase('tr-TR').replace(/\s+/g, ' ').trim();
}

function wireDuesPicker(scope) {
    var select = scope.querySelector('[data-dues-select]');
    var search = scope.querySelector('[data-dues-search]');
    var period = scope.querySelector('[data-dues-period]');
    var amount = scope.querySelector('[data-dues-amount]');
    var billingGroup = scope.querySelector('[data-dues-billing-group]');
    if (!select || select.dataset.wired === 'true') return;

    function syncSelected() {
        var option = select.selectedOptions[0];
        if (!option || !option.value) {
            if (billingGroup) billingGroup.value = '';
            return;
        }
        if (billingGroup) billingGroup.value = option.dataset.billingGroupId || '';
        if (amount && !amount.value) amount.value = option.dataset.amount || '';
    }

    function filterOptions() {
        var query = normalizeDuesSearch(search ? search.value : '');
        var selectedPeriod = period ? period.value : 'all';
        Array.from(select.options).forEach(function(option) {
            if (!option.value) return;
            var haystack = normalizeDuesSearch((option.dataset.search || '') + ' ' + option.textContent);
            var matchesSearch = query.length === 0 || haystack.includes(query);
            var matchesPeriod = selectedPeriod === 'all' || option.dataset.period === selectedPeriod;
            option.hidden = !matchesSearch || !matchesPeriod;
        });
    }

    select.addEventListener('change', syncSelected);
    if (search) search.addEventListener('input', filterOptions);
    if (period) period.addEventListener('change', filterOptions);
    select.dataset.wired = 'true';
    syncSelected();
    filterOptions();
}

document.querySelectorAll('.modal').forEach(wireDuesPicker);
syncIncomeFields();

(() => {
    const checkbox = document.getElementById("createCollectionIsReceipt");
    const legend = document.getElementById("createCollectionReferenceNoLegend");
    const input = document.getElementById("createCollectionReferenceNo");
    if (!checkbox || !legend || !input) return;

    const sync = () => {
        const isReceipt = checkbox.checked;
        legend.textContent = isReceipt ? "Makbuz No" : "Referans / Not";
        input.placeholder = isReceipt ? "Makbuz no" : "Referans no";
        syncIncomeFields();
    };

    checkbox.addEventListener("change", sync);
    sync();
})();
</script>
