@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Kişisel Veriler";
}

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-gray-700">Ana Sayfa</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Hesabımı Yönet</span>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Kişisel Veriler</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6">
        <partial name="_ManageNav" />

        <div class="space-y-5">
            @* Veri İndirme Kartı *@
            <div class="bg-white border border-gray-200 rounded-xl p-6">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-blue-600" style="font-size:22px">download</span>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-base font-semibold text-gray-900">Verilerimi İndir</h2>
                        <p class="text-sm text-gray-500 mt-1">
                            Hesabınıza ait kişisel verilerin bir kopyasını JSON formatında indirin.
                        </p>
                        <form method="post" asp-area="Identity" asp-page="/Account/Manage/DownloadPersonalData" class="mt-4">
                            <button type="submit" class="btn btn-outline btn-sm gap-2">
                                <span class="material-symbols-outlined" style="font-size:16px">download</span>
                                İndir
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            @* Hesap Silme Kartı *@
            <div class="bg-red-50/40 border border-red-200 rounded-xl p-6">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-red-600" style="font-size:22px">delete_forever</span>
                    </div>
                    <div class="flex-1">
                        <h2 class="text-base font-semibold text-red-900">Hesabımı Sil</h2>
                        <p class="text-sm text-red-700 mt-1">
                            Hesabınızı kalıcı olarak silin. Bu işlem geri alınamaz.
                        </p>
                        <div class="mt-4">
                            <a asp-area="Identity" asp-page="/Account/Manage/DeletePersonalData"
                               class="btn btn-error btn-outline btn-sm gap-2">
                                <span class="material-symbols-outlined" style="font-size:16px">delete_forever</span>
                                Hesabı Sil
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
