@model List<Kumburgaz.Web.Models.IncomeExpenseCategory>
@using Kumburgaz.Web.Services
@{
    ViewData["Title"] = "Kategori Ayarları";
}

<div class="space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
            <h2 class="text-2xl font-extrabold">Kategori Ayarları</h2>
            <p class="text-sm text-gray-400">Gelir/gider kategorileri</p>
        </div>
        <a class="btn btn-primary btn-sm" asp-action="Create">
            <span class="material-symbols-outlined ms-sm">add</span>
            Yeni Kategori
        </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Tür</th>
                        <th>Ad</th>
                        <th>Durum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @{
                                var typeDisplay = CategoryTypeHelper.Display(item.Type);
                                var typeBadge = typeDisplay == CategoryTypeHelper.Gelir ? "badge-success badge-soft" : "badge-error badge-soft";
                            }
                            <span class="badge @typeBadge">@typeDisplay</span>
                        </td>
                        <td class="font-medium">@item.Name</td>
                        <td>
                            @if (item.Active)
                            {
                                <span class="badge badge-success badge-soft">Aktif</span>
                            }
                            else
                            {
                                <span class="badge badge-ghost">Pasif</span>
                            }
                        </td>
                        <td>
                            <div class="flex justify-end gap-1">
                                <a class="btn btn-xs btn-ghost" asp-action="Edit" asp-route-id="@item.Id">
                                    <span class="material-symbols-outlined ms-sm">edit</span>
                                    Düzenle
                                </a>
                                <form asp-action="Toggle" asp-route-id="@item.Id" method="post">
                                    <button class="btn btn-xs btn-ghost" type="submit">
                                        <span class="material-symbols-outlined ms-sm">toggle_on</span>
                                        Durum
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
