@model List<Kumburgaz.Web.Models.DuesType>
@{
    ViewData["Title"] = "Aidat Tipleri";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Aidat Tipleri</h2>
    <a class="btn btn-primary" asp-action="Create">Yeni Tip</a>
</div>

@if (TempData["ActionSuccess"] is string actionSuccess)
{
    <div class="alert alert-success">@actionSuccess</div>
}
@if (TempData["ActionError"] is string actionError)
{
    <div class="alert alert-danger">@actionError</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Tutar (TL)</th>
            <th>Durum</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Amount.ToString("N2")</td>
            <td>@(item.Active ? "Aktif" : "Pasif")</td>
            <td class="d-flex gap-1">
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                      onsubmit="return confirm('Bu aidat tipi silinsin mi?');">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
