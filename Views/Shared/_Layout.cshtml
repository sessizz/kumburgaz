@inject Kumburgaz.Web.Services.PermissionService Perm
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var settingsControllers = new[] { "Settings", "DuesTypes", "BillingGroups", "IncomeExpenseCategories", "Blocks", "OpeningBalances" };

    string IsActive(params string[] controllers) =>
        controllers.Contains(currentController, StringComparer.OrdinalIgnoreCase) ? "active" : string.Empty;

    string IsActiveAction(string controller, string action) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : string.Empty;

    string PageTitle() => ViewData["Title"]?.ToString() ?? "Kumburgaz Yönetim";
}
<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@PageTitle() - Kumburgaz Yönetim</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/document-preview.css" asp-append-version="true" />

    <style type="text/tailwindcss">
        @@theme {
            --font-sans: "Inter", system-ui, sans-serif;
            --color-primary: #0e7c86;
            --color-primary-content: #ffffff;
            --color-blue-50: #eef6f7;
            --color-blue-100: #dbeef0;
            --color-blue-200: #bfe0e2;
            --color-blue-300: #94cbcf;
            --color-blue-400: #57adb3;
            --color-blue-500: #1f8f97;
            --color-blue-600: #0e7c86;
            --color-blue-700: #0a5c64;
            --color-blue-800: #0a4a51;
            --color-blue-900: #0b3d43;
            --color-blue-950: #062327;
        }
    </style>
    <style>
        :root, html[data-theme="light"] {
            --color-primary: #0e7c86 !important;
            --color-primary-content: #ffffff !important;
        }
        /* daisyui's own theme stylesheet wins the cascade over the custom
           property override above, so force the rendered properties directly
           on the components that matter. */
        .btn.btn-primary { background-color:#0e7c86 !important; border-color:#0a5c64 !important; color:#fff !important; }
        .btn.btn-primary:hover { background-color:#0a5c64 !important; border-color:#0a5c64 !important; }
        .btn.btn-outline.btn-primary { background-color:transparent !important; color:#0e7c86 !important; border-color:#0e7c86 !important; }
        .btn.btn-outline.btn-primary:hover { background-color:#0e7c86 !important; color:#fff !important; }
        .link-primary, .text-primary { color:#0e7c86 !important; }
        .checkbox:checked, .radio:checked, .toggle:checked { background-color:#0e7c86 !important; border-color:#0e7c86 !important; }
        * { font-family: "Inter", system-ui, sans-serif; }
        .material-symbols-outlined {
            font-family: 'Material Symbols Outlined' !important;
            font-weight: normal;
            font-style: normal;
            font-size: 20px;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
            font-feature-settings: 'liga';
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 22;
            vertical-align: middle;
        }

        .dk-side { background:#ffffff; color:#3d5a64; border-right:1px solid #dde8ea; }
        .dk-nav { display:flex; align-items:center; gap:12px; padding:10px 14px; border-radius:8px; color:#4b6c76; font-size:14px; font-weight:500; cursor:pointer; transition:background .15s, color .15s; text-decoration:none; }
        .dk-nav:hover { background:#eef6f7; color:#0a5c64; }
        .dk-nav.active { background:#e2f1f2; color:#0a5c64; font-weight:600; box-shadow:none; }
        .dk-nav .mi { font-size:20px; width:22px; text-align:center; }
        .dk-section { color:#8aa3ab; font-size:11px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:14px 14px 5px; }
        .pill { display:inline-flex; align-items:center; gap:6px; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; letter-spacing:.02em; text-transform:uppercase; }
        .pill-ok { background:#e3f2ea; color:#1e7a4f; border:1px solid #bfe3cf; }
        .pill-warn { background:#faf3d9; color:#8a6d1a; border:1px solid #efdfa0; }
        .pill-info { background:#e2f1f2; color:#0a5c64; border:1px solid #bfe0e2; }
        .pill-muted { background:#eef2f3; color:#557079; border:1px solid #dde8ea; }
        .pill-neg { background:#fbeae9; color:#c94040; border:1px solid #f2cfcd; }
        .ico { width:44px; height:44px; border-radius:999px; display:flex; align-items:center; justify-content:center; flex:none; }
        .day { text-align:center; padding:8px 0; border-radius:10px; cursor:pointer; transition:background .12s; }
        .day:hover { background:#f3f4f6; }
        .day .lbl { font-size:11px; color:#9ca3af; font-weight:500; }
        .day .num { font-size:18px; color:#111827; font-weight:600; margin-top:2px; }
        .day .marker { width:6px; height:6px; border-radius:999px; margin:6px auto 0; background:#e5e7eb; }
        .day .marker.r { background:#ef4444; }
        .day .marker.b { background:#3b82f6; }
        .day .marker.g { background:#10b981; }
        .day.is-today { background:#0e7c86; }
        .day.is-today .lbl { color:rgba(255,255,255,.85); }
        .day.is-today .num { background:#fff; color:#0e7c86; width:32px; height:32px; border-radius:999px; display:inline-flex; align-items:center; justify-content:center; line-height:1; }
        .day.is-today .marker { background:rgba(255,255,255,.85); }
        .hbar-track { height:8px; border-radius:999px; background:#f1f5f9; overflow:hidden; }
        .cf-val { opacity:0; transition:opacity .15s ease; pointer-events:none; }
        .cf-val text { paint-order:stroke; stroke:#fff; stroke-width:3px; stroke-linejoin:round; }
        .cf-group:hover .cf-val { opacity:1; }
        .hbar-fill { height:100%; border-radius:999px; }
        .tbl-row { display:grid; align-items:center; padding:8px 0; }
        .tbl-row + .tbl-row { border-top:1px solid #f3f4f6; }
        .tbl-h { color:#9ca3af; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.06em; }
        .ms-sm { font-size:18px; }
        ::-webkit-scrollbar { width:5px; height:5px; }
        ::-webkit-scrollbar-thumb { background:#d1d5db; border-radius:99px; }

        html[data-theme="light"] body .badge {
            background-color:#eef2f3 !important;
            border-color:#eef2f3 !important;
            color:#3d5a64 !important;
            font-weight:700;
        }
        html[data-theme="light"] body .badge.badge-success {
            background-color:#e3f2ea !important;
            border-color:#e3f2ea !important;
            color:#1e7a4f !important;
        }
        html[data-theme="light"] body .badge.badge-info {
            background-color:#e2f1f2 !important;
            border-color:#e2f1f2 !important;
            color:#0a5c64 !important;
        }
        html[data-theme="light"] body .badge.badge-warning {
            background-color:#faf3d9 !important;
            border-color:#faf3d9 !important;
            color:#8a6d1a !important;
        }
        html[data-theme="light"] body .badge.badge-error {
            background-color:#fbeae9 !important;
            border-color:#fbeae9 !important;
            color:#c94040 !important;
        }
        html[data-theme="light"] body .badge.badge-primary {
            background-color:#0e7c86 !important;
            border-color:#0e7c86 !important;
            color:#eef6f7 !important;
        }
        html[data-theme="light"] body .badge.badge-ghost {
            background-color:#eef2f3 !important;
            border-color:#eef2f3 !important;
            color:#557079 !important;
        }
        html[data-theme="light"] body .badge.ledger-category-0  { background-color:#e2eef8 !important; border-color:#e2eef8 !important; color:#2b6a9e !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-1  { background-color:#faf3d9 !important; border-color:#faf3d9 !important; color:#8a6d1a !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-2  { background-color:#e3f2ea !important; border-color:#e3f2ea !important; color:#1e7a4f !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-3  { background-color:#e9e6f8 !important; border-color:#e9e6f8 !important; color:#5b4bab !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-4  { background-color:#fbe7ea !important; border-color:#fbe7ea !important; color:#b23a55 !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-5  { background-color:#dbeef0 !important; border-color:#dbeef0 !important; color:#0a5c64 !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-6  { background-color:#e6e6f7 !important; border-color:#e6e6f7 !important; color:#4a4aa0 !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-7  { background-color:#eef5d9 !important; border-color:#eef5d9 !important; color:#5c7a1a !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-8  { background-color:#f8e6f6 !important; border-color:#f8e6f6 !important; color:#9a3f96 !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-9  { background-color:#fbeadd !important; border-color:#fbeadd !important; color:#b0622a !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-10 { background-color:#dff5f7 !important; border-color:#dff5f7 !important; color:#217680 !important; font-weight:700; }
        html[data-theme="light"] body .badge.ledger-category-11 { background-color:#eef2f3 !important; border-color:#eef2f3 !important; color:#557079 !important; font-weight:700; }
    </style>
</head>
<body style="background:#f3f4f6; min-height:100vh; display:flex;">
    <input type="checkbox" id="sidebar-toggle" class="hidden peer/sidebar" />

    <aside class="dk-side fixed lg:static inset-y-0 left-0 z-40 flex flex-col w-60 shrink-0 min-h-screen transition-transform -translate-x-full lg:translate-x-0 peer-checked/sidebar:translate-x-0">
        <div class="flex items-center gap-2 px-5 py-4 border-b border-gray-100">
            <label for="sidebar-toggle" class="lg:hidden cursor-pointer text-gray-400 hover:text-gray-700 mr-1">
                <span class="material-symbols-outlined">close</span>
            </label>
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:linear-gradient(160deg,#0e7c86,#0a5c64);">
                <span class="material-symbols-outlined text-white" style="font-size:20px;">apartment</span>
            </div>
            <span class="text-base font-bold text-gray-900 tracking-tight">kumburgaz</span>
        </div>

        @{
            var showYonetim = Perm.CanView(User, AppModules.Daireler) || Perm.CanView(User, AppModules.Hesaplar);
            var showFinans = Perm.CanView(User, AppModules.Aidatlar) || Perm.CanView(User, AppModules.Muhasebe) || Perm.CanView(User, AppModules.KasaBanka);
            var showIslemler = Perm.CanView(User, AppModules.Duyurular) || Perm.CanView(User, AppModules.Talepler);
            var showArsiv = Perm.CanView(User, AppModules.Belgeler) || Perm.CanView(User, AppModules.Raporlar);
            var showAyarlar = User.IsInRole(AppRoles.SistemYonetici);
        }
        <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
            @if (Perm.CanView(User, AppModules.Panel))
            {
                <a class="dk-nav @IsActive("Home")" asp-controller="Home" asp-action="Index"><span class="mi material-symbols-outlined">dashboard</span>Genel Bakış</a>
            }
            @if (showYonetim)
            {
                <div class="dk-section">Yönetim</div>
                @if (Perm.CanView(User, AppModules.Daireler))
                {
                    <a class="dk-nav @IsActive("Units")" asp-controller="Units" asp-action="Index"><span class="mi material-symbols-outlined">apartment</span>Daireler</a>
                }
                @if (Perm.CanView(User, AppModules.Hesaplar))
                {
                    <a class="dk-nav @IsActive("Accounts")" asp-controller="Accounts" asp-action="Index"><span class="mi material-symbols-outlined">contacts</span>Hesaplar</a>
                }
            }
            @if (showFinans)
            {
                <div class="dk-section">Finans</div>
                @if (Perm.CanView(User, AppModules.Aidatlar))
                {
                    <a class="dk-nav @IsActive("Dues", "Collections", "DuesGeneration")" asp-controller="Dues" asp-action="Index"><span class="mi material-symbols-outlined">receipt_long</span>Aidatlar</a>
                }
                @if (Perm.CanView(User, AppModules.Muhasebe))
                {
                    <a class="dk-nav @IsActiveAction("Ledger", "Income")" asp-controller="Ledger" asp-action="Income"><span class="mi material-symbols-outlined">trending_up</span>Gelirler</a>
                    <a class="dk-nav @IsActiveAction("Ledger", "Index")" asp-controller="Ledger" asp-action="Index"><span class="mi material-symbols-outlined">payments</span>Giderler</a>
                }
                @if (Perm.CanView(User, AppModules.KasaBanka))
                {
                    <a class="dk-nav @IsActive("CashBank")" asp-controller="CashBank" asp-action="Index"><span class="mi material-symbols-outlined">account_balance_wallet</span>Kasa &amp; Banka</a>
                }
            }
            @if (showIslemler)
            {
                <div class="dk-section">İşlemler</div>
                @if (Perm.CanView(User, AppModules.Duyurular))
                {
                    <a class="dk-nav @IsActive("Announcements")" asp-controller="Announcements" asp-action="Index"><span class="mi material-symbols-outlined">campaign</span>Duyurular</a>
                }
                @if (Perm.CanView(User, AppModules.Talepler))
                {
                    <a class="dk-nav @IsActive("Requests")" asp-controller="Requests" asp-action="Index"><span class="mi material-symbols-outlined">support_agent</span>Talepler</a>
                }
            }
            @if (showArsiv)
            {
                <div class="dk-section">Arşiv &amp; Raporlar</div>
                @if (Perm.CanView(User, AppModules.Belgeler))
                {
                    <a class="dk-nav @IsActive("Documents")" asp-controller="Documents" asp-action="Index"><span class="mi material-symbols-outlined">folder</span>Belgeler</a>
                }
                @if (Perm.CanView(User, AppModules.Raporlar))
                {
                    <a class="dk-nav @IsActive("Reports")" asp-controller="Reports" asp-action="Index"><span class="mi material-symbols-outlined">bar_chart</span>Raporlar</a>
                }
            }
            @if (showAyarlar)
            {
                <a class="dk-nav @(settingsControllers.Contains(currentController, StringComparer.OrdinalIgnoreCase) || string.Equals(currentController, "SystemUsers", StringComparison.OrdinalIgnoreCase) || string.Equals(currentController, "RolePermissions", StringComparison.OrdinalIgnoreCase) ? "active" : "")" asp-controller="Settings" asp-action="Index"><span class="mi material-symbols-outlined">settings</span>Ayarlar</a>
            }
        </nav>

    </aside>

    <div class="flex-1 flex flex-col min-h-screen min-w-0">
        <header class="sticky top-0 z-30 bg-white border-b border-gray-200 flex items-center gap-3 px-5 h-16">
            <label for="sidebar-toggle" class="lg:hidden cursor-pointer text-gray-500 hover:text-gray-800">
                <span class="material-symbols-outlined">menu</span>
            </label>
            <div class="flex-1 max-w-xl">
                <div class="relative" data-unit-search data-search-url="@Url.Action("Global", "Search")">
                    <label class="flex items-center gap-2 h-10 px-3 rounded-lg border border-gray-200 bg-gray-50/60 hover:bg-white hover:border-gray-300 focus-within:bg-white focus-within:border-blue-300 focus-within:ring-2 focus-within:ring-blue-100 transition">
                        <span class="material-symbols-outlined text-gray-400">search</span>
                        <input id="global-unit-search" class="grow bg-transparent text-sm outline-none placeholder:text-gray-400" type="search" autocomplete="off" placeholder="Daire, malik, makbuz, kategori veya işlem ara (Ctrl+K)" aria-label="Global ara" aria-autocomplete="list" aria-expanded="false" aria-controls="global-unit-search-results" />
                        <kbd class="hidden md:inline-flex items-center gap-1 text-[10px] font-semibold text-gray-400 bg-white border border-gray-200 rounded px-1.5 py-0.5">⌘K</kbd>
                    </label>
                    <div id="global-unit-search-results" class="hidden absolute left-0 right-0 top-full mt-2 bg-white border border-gray-200 rounded-xl shadow-xl overflow-hidden z-50" role="listbox" aria-label="Hesap arama sonuçları"></div>
                </div>
            </div>
            <div class="ml-auto flex items-center gap-3">
                <button class="relative w-10 h-10 rounded-lg hover:bg-gray-100 flex items-center justify-center text-gray-600">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center px-1">7</span>
                </button>
                <button class="hidden sm:flex w-10 h-10 rounded-lg hover:bg-gray-100 items-center justify-center text-gray-600">
                    <span class="material-symbols-outlined">help</span>
                </button>
                <div class="ml-1 flex items-center gap-3 pl-3 border-l border-gray-200 h-10">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        <main class="flex-1 p-5 lg:p-6">
            <div class="max-w-[1400px] mx-auto">
                @RenderBody()
            </div>
        </main>
    </div>

    @* Paylasilan fotograf lightbox'i: herhangi bir sayfa openLightbox(url) cagirarak
       fotografi indirmek/yeni sekme acmak yerine ayni sayfada buyuk gosterir. *@
    <dialog id="photoLightbox" class="modal">
        <div class="modal-box max-w-3xl p-2 bg-transparent shadow-none">
            <button type="button" class="btn btn-sm btn-circle absolute right-2 top-2 z-10" onclick="closeLightbox()">✕</button>
            <img id="photoLightboxImg" src="" alt="Fotoğraf" class="w-full h-auto rounded-lg" />
        </div>
        <form method="dialog" class="modal-backdrop"><button>kapat</button></form>
    </dialog>
    <script>
        function openLightbox(url) {
            document.getElementById('photoLightboxImg').src = url;
            document.getElementById('photoLightbox').showModal();
        }
        function closeLightbox() {
            document.getElementById('photoLightbox').close();
            document.getElementById('photoLightboxImg').src = '';
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
