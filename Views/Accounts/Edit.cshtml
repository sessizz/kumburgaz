@model Kumburgaz.Web.Models.AccountEditPageViewModel
@{
    ViewData["Title"] = "Hesap Düzenle";
}

<div class="max-w-2xl mx-auto space-y-4">
    <div class="flex items-center gap-3">
        <a class="btn btn-ghost btn-sm btn-square" asp-action="Index" title="Geri">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h2 class="text-2xl font-extrabold">Hesap Düzenle</h2>
    </div>

    @if (TempData["ActionSuccess"] is string okMsg)
    {
        <div class="alert alert-success text-sm">@okMsg</div>
    }
    @if (TempData["ActionError"] is string errMsg)
    {
        <div class="alert alert-error text-sm">@errMsg</div>
    }

    <partial name="_Form" model="Model.Form" />

    @if (Model.IsResidentAccount)
    {
        <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-4">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-blue-600">apartment</span>
                <h3 class="text-lg font-bold">Daire Erişimi</h3>
            </div>
            <p class="text-sm text-gray-500">Sakin, aşağıdaki dairelerin borç/tahakkuk/ödeme bilgisini mobil uygulamada görebilir ve bu daireler için mahsuplu gider girebilir.</p>

            <div>
                <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">Sahiplik (otomatik)</div>
                @if (Model.OwnedUnits.Count == 0)
                {
                    <div class="text-sm text-gray-400">Bu hesabın sahip olduğu daire yok.</div>
                }
                else
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var u in Model.OwnedUnits)
                        {
                            <span class="badge badge-ghost gap-1">@u.Display <span class="opacity-60">· @u.Role</span></span>
                        }
                    </div>
                }
            </div>

            <div>
                <div class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">Ek erişim (yönetici tanımlar)</div>
                @if (Model.GrantedUnits.Count == 0)
                {
                    <div class="text-sm text-gray-400">Ek erişim tanımlı değil.</div>
                }
                else
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var u in Model.GrantedUnits)
                        {
                            <form method="post" asp-action="RemoveUnitAccess" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="accountId" value="@Model.Form.Id" />
                                <input type="hidden" name="unitId" value="@u.UnitId" />
                                <button type="submit" class="badge badge-primary gap-1" title="Kaldır">
                                    @u.Display <span class="material-symbols-outlined text-[16px]">close</span>
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>

            @if (Model.UnitOptions.Count > 0)
            {
                <form method="post" asp-action="AddUnitAccess" class="flex items-end gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="accountId" value="@Model.Form.Id" />
                    <div class="grow">
                        <label class="text-xs font-semibold text-gray-500">Daire ekle</label>
                        <select name="unitId" class="select select-bordered w-full">
                            @foreach (var opt in Model.UnitOptions)
                            {
                                <option value="@opt.Value">@opt.Text</option>
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Ekle</button>
                </form>
            }
        </div>

        @if (Model.CanManageLogin)
        {
            <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-3">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-blue-600">key</span>
                    <h3 class="text-lg font-bold">Mobil Giriş Bilgileri</h3>
                </div>
                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div>
                        <div class="text-xs text-gray-400 uppercase font-semibold">Kullanıcı adı</div>
                        <div class="font-mono font-bold text-base">@Model.UserName</div>
                    </div>
                    <div>
                        <div class="text-xs text-gray-400 uppercase font-semibold">Şifre (PIN)</div>
                        <div class="font-mono font-bold text-base">@(Model.MobilePassword ?? "—")</div>
                    </div>
                </div>
                @if (!Model.HasLogin)
                {
                    <div class="alert alert-warning text-sm py-2">Bu hesabın henüz mobil girişi yok. "Yeni şifre üret" ile oluşturabilirsiniz.</div>
                }
                <form method="post" asp-action="ResetMobilePassword">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="accountId" value="@Model.Form.Id" />
                    <button type="submit" class="btn btn-outline btn-sm">
                        <span class="material-symbols-outlined text-[18px]">autorenew</span>
                        @(Model.HasLogin ? "Yeni şifre üret" : "Giriş oluştur")
                    </button>
                </form>
            </div>
        }
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
