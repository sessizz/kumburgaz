@model Kumburgaz.Web.Models.DuesType
@{
    ViewData["Title"] = "Aidat Tipi Düzenle";
}

<div class="max-w-xl mx-auto space-y-4">
    <div class="flex items-center gap-3">
        <a class="btn btn-ghost btn-sm btn-square" asp-action="Index" title="Geri">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h2 class="text-2xl font-extrabold">Aidat Tipi Düzenle</h2>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="p-6">
            <form asp-action="Edit" method="post" class="space-y-4">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm py-2"></div>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Ad</legend>
                    <input asp-for="Name" class="input input-bordered w-full" />
                    <span asp-validation-for="Name" class="text-error text-xs"></span>
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Tutar (TL)</legend>
                    <input asp-for="Amount" class="input input-bordered w-full" />
                    <span asp-validation-for="Amount" class="text-error text-xs"></span>
                </fieldset>
                <label class="label cursor-pointer justify-start gap-3">
                    <input asp-for="Active" class="toggle toggle-primary" />
                    <span class="label-text">Aktif</span>
                </label>
                <div class="flex gap-2 justify-end pt-2">
                    <a class="btn btn-ghost" asp-action="Index">Vazgeç</a>
                    <button class="btn btn-primary" type="submit">
                        <span class="material-symbols-outlined ms-sm">save</span>
                        Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
