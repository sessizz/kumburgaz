@model List<Kumburgaz.Web.Models.DuesDebtReportRow>
@using Kumburgaz.Web.Models
@using Kumburgaz.Web.Services
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Hesap Ekstresi";
    var query = (DuesDebtReportQuery)ViewBag.Query;
    var summary = DuesDebtSummaryHelper.Build(Model);
}

<div class="space-y-4">
    <div class="flex items-center justify-between gap-3">
        <div>
            <h2 class="text-2xl font-extrabold">Hesap Ekstresi</h2>
            <p class="text-sm text-gray-400">Aidat tahakkuklarını, kalan borçları ve alacak bakiyelerini görüntüleyebilirsiniz.</p>
        </div>
        <a class="btn btn-ghost btn-sm" asp-action="Index">
            <span class="material-symbols-outlined ms-sm">arrow_back</span>
            Raporlar
        </a>
    </div>

    @if (TempData["Success"] is string successMessage)
    {
        <div class="alert alert-success">
            <span class="material-symbols-outlined">check_circle</span>
            <span>@successMessage</span>
        </div>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <div class="alert alert-error">
            <span class="material-symbols-outlined">error</span>
            <span>@errorMessage</span>
        </div>
    }

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
        <div class="p-6">
            <form method="get" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Dönem</legend>
                        <select class="select select-bordered" name="Period" asp-items="(IEnumerable<SelectListItem>)ViewBag.Periods"></select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Blok</legend>
                        <select class="select select-bordered" name="BlockId" asp-items="(IEnumerable<SelectListItem>)ViewBag.Blocks">
                            <option value="">Tüm</option>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Aidat Tipi</legend>
                        <select class="select select-bordered" name="DuesTypeId" asp-items="(IEnumerable<SelectListItem>)ViewBag.DuesTypes">
                            <option value="">Tüm</option>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Aidatlandırma Grubu</legend>
                        <select class="select select-bordered" name="BillingGroupId" asp-items="(IEnumerable<SelectListItem>)ViewBag.BillingGroups">
                            <option value="">Tüm</option>
                        </select>
                    </fieldset>
                    <fieldset class="fieldset">
                        <legend class="fieldset-legend">Borç Durumu</legend>
                        <select class="select select-bordered" name="BalanceStatus" asp-items="(IEnumerable<SelectListItem>)ViewBag.BalanceStatuses">
                            <option value="">Tümü</option>
                        </select>
                    </fieldset>
                </div>
                <div class="flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="submit">
                        <span class="material-symbols-outlined ms-sm">filter_alt</span>
                        Filtrele
                    </button>
                    <a class="btn btn-outline btn-success" asp-action="DuesDebtExcel"
                       asp-route-Period="@query.Period"
                       asp-route-BlockId="@query.BlockId"
                       asp-route-DuesTypeId="@query.DuesTypeId"
                       asp-route-BillingGroupId="@query.BillingGroupId"
                       asp-route-BalanceStatus="@query.BalanceStatus">
                        <span class="material-symbols-outlined ms-sm">table_chart</span>
                        Excel
                    </a>
                    <a class="btn btn-outline btn-error" asp-action="DuesDebtPdf"
                       asp-route-Period="@query.Period"
                       asp-route-BlockId="@query.BlockId"
                       asp-route-DuesTypeId="@query.DuesTypeId"
                       asp-route-BillingGroupId="@query.BillingGroupId"
                       asp-route-BalanceStatus="@query.BalanceStatus">
                        <span class="material-symbols-outlined ms-sm">picture_as_pdf</span>
                        PDF
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Daire/Birleşik</th>
                        <th>Sorumlu Hesap</th>
                        <th>Aidat Tipi</th>
                        <th>Aidat Grubu</th>
                        <th class="text-end">Tahakkuk Toplamı</th>
                        <th class="text-end">Bakiye</th>
                        <th>Durum</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td class="font-medium">
                            @if (row.UnitId.HasValue)
                            {
                                <a class="text-blue-600 hover:underline"
                                   asp-controller="Units"
                                   asp-action="Detail"
                                   asp-route-id="@row.UnitId.Value">@row.UnitDisplay</a>
                            }
                            else
                            {
                                @row.UnitDisplay
                            }
                        </td>
                        <td class="text-sm">
                            @if (row.UnitId.HasValue && !string.IsNullOrWhiteSpace(row.ResponsibleAccountName))
                            {
                                <a class="text-blue-600 hover:underline"
                                   asp-controller="Units"
                                   asp-action="Detail"
                                   asp-route-id="@row.UnitId.Value">@row.ResponsibleAccountName</a>
                            }
                            else
                            {
                                @(string.IsNullOrWhiteSpace(row.ResponsibleAccountName) ? "-" : row.ResponsibleAccountName)
                            }
                        </td>
                        <td><span class="badge badge-info badge-soft">@row.DuesTypeName</span></td>
                        <td>@row.BillingGroupName</td>
                        <td class="text-end font-bold">@row.Amount.ToString("N2")</td>
                        <td class="text-end font-bold @(row.RemainingAmount > 0 ? "text-error" : row.RemainingAmount < 0 ? "text-info" : "text-success")">
                            @Math.Abs(row.RemainingAmount).ToString("N2")
                        </td>
                        <td>
                            <span class="badge @(row.RemainingAmount > 0 ? "badge-error badge-soft" : row.RemainingAmount < 0 ? "badge-info badge-soft" : "badge-success badge-soft")">
                                @(row.RemainingAmount > 0 ? "Borç" : row.RemainingAmount < 0 ? "Alacak" : "Yok")
                            </span>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-sm text-gray-500 py-8">Filtreye uygun hesap ekstresi bulunamadı.</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-200">
            <h3 class="text-base font-extrabold text-gray-900">İcmal</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-gray-100">
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Borçlu</div>
                <div class="mt-2 text-2xl font-extrabold text-error tabular-nums">@summary.DebtorCount</div>
                <div class="mt-1 text-sm font-bold text-gray-900 tabular-nums">@summary.TotalDebt.ToString("N2") TL</div>
                <div class="mt-1 text-xs text-gray-400 tabular-nums">Bu dönem @summary.CurrentPeriodDebt.ToString("N2") · Devirden @summary.CarriedOverDebt.ToString("N2")</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Alacaklı</div>
                <div class="mt-2 text-2xl font-extrabold text-info tabular-nums">@summary.CreditorCount</div>
                <div class="mt-1 text-sm font-bold text-gray-900 tabular-nums">@summary.TotalCredit.ToString("N2") TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Bakiyesiz</div>
                <div class="mt-2 text-2xl font-extrabold text-success tabular-nums">@summary.ClearCount</div>
                <div class="mt-1 text-sm font-bold text-gray-900 tabular-nums">0,00 TL</div>
            </div>
            <div class="p-5">
                <div class="text-xs font-semibold uppercase tracking-wider text-gray-400">Net Bakiye</div>
                <div class="mt-2 text-2xl font-extrabold @(summary.NetBalance > 0 ? "text-error" : summary.NetBalance < 0 ? "text-info" : "text-success") tabular-nums">@Math.Abs(summary.NetBalance).ToString("N2") TL</div>
                <div class="mt-1 text-sm text-gray-500 tabular-nums">Tahakkuk: @summary.TotalAccrual.ToString("N2") TL</div>
            </div>
        </div>
    </div>
</div>
