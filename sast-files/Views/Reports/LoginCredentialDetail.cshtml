@model Kumburgaz.Web.Models.ResidentCredentialRow
@{
    ViewData["Title"] = "Giriş Bilgisi";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
    var loginUrl = $"{baseUrl}/m";
    var shareText = $"Kumburgaz mobil uygulaması giriş bilgileriniz:\nAdres: {loginUrl}\nKullanıcı adı: {Model.UserName}\nŞifre: {Model.Password}";
}

<div class="max-w-xl mx-auto space-y-4">
    <div class="flex items-center gap-3">
        <a class="btn btn-ghost btn-sm btn-square" asp-action="LoginCredentials" title="Geri">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <div>
            <h2 class="text-2xl font-extrabold">@Model.AccountName</h2>
            <p class="text-sm text-gray-500">@Model.AccountTypeLabel · @(string.IsNullOrEmpty(Model.Units) ? "Daire yok" : Model.Units)</p>
        </div>
    </div>

    @if (!Model.HasLogin || string.IsNullOrEmpty(Model.Password))
    {
        <div class="alert alert-warning text-sm">Bu hesabın henüz mobil girişi yok. Hesabı düzenleyip "Giriş oluştur" ile PIN üretin.</div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-200 p-5">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <div class="text-xs text-gray-400 uppercase font-semibold">Kullanıcı adı</div>
                    <div class="font-mono font-extrabold text-2xl">@Model.UserName</div>
                </div>
                <div>
                    <div class="text-xs text-gray-400 uppercase font-semibold">Şifre (PIN)</div>
                    <div class="font-mono font-extrabold text-2xl">@Model.Password</div>
                </div>
            </div>
            <div class="mt-4">
                <div class="text-xs text-gray-400 uppercase font-semibold">Giriş adresi</div>
                <a class="text-sky-600 hover:underline break-all" href="@loginUrl">@loginUrl</a>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 p-5 space-y-2">
            <div class="flex items-center justify-between">
                <h3 class="font-bold">Paylaşılabilir mesaj</h3>
                <button type="button" class="btn btn-outline btn-sm" onclick="navigator.clipboard.writeText(document.getElementById('shareText').value).then(()=>{this.textContent='Kopyalandı';})">Kopyala</button>
            </div>
            <textarea id="shareText" class="textarea textarea-bordered w-full min-h-32 font-mono text-sm" readonly>@shareText</textarea>
            <p class="text-xs text-gray-500">Bu mesajı sakinle paylaşabilirsiniz; verdiğiniz adrese girip kullanıcı adı ve şifresiyle doğrudan giriş yapar.</p>
        </div>
    }
</div>
