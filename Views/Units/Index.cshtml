@model List<Kumburgaz.Web.Models.Unit>
@{
    ViewData["Title"] = "Daireler";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Daireler</h2>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="ExportCsv">CSV Dışa Aktar</a>
        <a class="btn btn-primary" asp-action="Create">Yeni Daire</a>
    </div>
</div>

@if (TempData["ImportSuccess"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ImportError"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}
@if (TempData["ActionSuccess"] is string actionSuccess)
{
    <div class="alert alert-success">@actionSuccess</div>
}
@if (TempData["ActionError"] is string actionError)
{
    <div class="alert alert-danger">@actionError</div>
}

<form asp-action="ImportCsv" method="post" enctype="multipart/form-data" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-7">
            <label class="form-label mb-1">Daire CSV Yükle</label>
            <input type="file" name="file" accept=".csv,text/csv" class="form-control" />
            <div class="form-text">Kolonlar: BlockId veya Block, UnitNo, OwnerName, Active. Birleşik daireleri formdan oluşturun.</div>
        </div>
        <div class="col-md-5">
            <button type="submit" class="btn btn-outline-primary">CSV ile Ekle</button>
        </div>
    </div>
</form>

<form asp-action="DeleteSelected" method="post" id="bulkDeleteUnitsForm"
      onsubmit="return confirmUnitsFormSubmit(event);">
    @Html.AntiForgeryToken()

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="selectAllUnits" />
            <label class="form-check-label" for="selectAllUnits">Tümünü seç</label>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary btn-sm"
                    type="submit"
                    formaction="@Url.Action("CombineSelected", "Units")"
                    data-bulk-action="combine">
                Birleştir
            </button>
            <button class="btn btn-outline-danger btn-sm" type="submit" data-bulk-action="delete">Seçilenleri Sil</button>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th style="width: 44px;"></th>
                <th>Blok</th>
                <th>Daire No</th>
                <th>Malik</th>
                <th>Tip</th>
                <th>Bileşenler</th>
                <th>Durum</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <input class="form-check-input unit-select" type="checkbox" name="selectedUnitIds" value="@item.Id" />
                </td>
                <td>@item.Block?.Name</td>
                <td>@item.UnitNo</td>
                <td>@item.OwnerName</td>
                <td>@(item.IsCombined ? "Birleşik" : "Fiziksel")</td>
                <td>
                    @if (item.IsCombined)
                    {
                        @string.Join(" + ", item.CombinedUnitMembers
                            .Where(x => x.ComponentUnit?.Block is not null)
                            .Select(x => $"{x.ComponentUnit!.Block!.Name}-{x.ComponentUnit.UnitNo}")
                            .OrderBy(x => x))
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>@(item.Active ? "Aktif" : "Pasif")</td>
                <td class="d-flex gap-1">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                    <button class="btn btn-sm btn-outline-danger"
                            type="submit"
                            formmethod="post"
                            formaction="@Url.Action("Delete", "Units", new { id = item.Id })"
                            data-bulk-action="single-delete">
                        Sil
                    </button>
                </td>
            </tr>
        }
        </tbody>
    </table>
</form>

@section Scripts {
    <script>
        const selectAllUnits = document.getElementById("selectAllUnits");
        const unitCheckboxes = Array.from(document.querySelectorAll(".unit-select"));

        selectAllUnits?.addEventListener("change", () => {
            unitCheckboxes.forEach((checkbox) => {
                checkbox.checked = selectAllUnits.checked;
            });
        });

        unitCheckboxes.forEach((checkbox) => {
            checkbox.addEventListener("change", () => {
                if (!selectAllUnits) {
                    return;
                }

                selectAllUnits.checked = unitCheckboxes.length > 0 && unitCheckboxes.every((item) => item.checked);
                selectAllUnits.indeterminate = unitCheckboxes.some((item) => item.checked) && !selectAllUnits.checked;
            });
        });

        function selectedUnitCount() {
            return unitCheckboxes.filter((checkbox) => checkbox.checked).length;
        }

        function confirmUnitsFormSubmit(event) {
            const action = event.submitter?.dataset?.bulkAction;
            if (action === "single-delete") {
                return confirm("Bu daire silinsin mi?");
            }

            if (action === "combine") {
                return confirmSelectedUnitsCombine();
            }

            return confirmSelectedUnitsDelete();
        }

        function confirmSelectedUnitsDelete() {
            const selectedCount = selectedUnitCount();
            if (selectedCount === 0) {
                alert("Silmek için en az bir daire seçin.");
                return false;
            }

            return confirm(`${selectedCount} daire silinsin mi? Bağlı kayıt içeren daireler atlanır.`);
        }

        function confirmSelectedUnitsCombine() {
            const selectedCount = selectedUnitCount();
            if (selectedCount !== 2) {
                alert("Birleştirmek için tam 2 daire seçin.");
                return false;
            }

            return confirm("Seçilen 2 daire birleşik daireye dönüştürülsün mü?");
        }
    </script>
}
