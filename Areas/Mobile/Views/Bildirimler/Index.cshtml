@model List<MobileNotificationRow>
@{
    ViewData["Title"] = "Bildirimler";
    var unreadCount = Model.Count(x => !x.IsRead);

    string TypeIcon(NotificationType t) => t switch
    {
        NotificationType.TalepAtama => "M9 12l2 2 4-4M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
        NotificationType.TalepDurum => "M9 12l2 2 4-4M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
        NotificationType.Duyuru => "M3 11l18-5v12L3 14v-3z",
        _ => "M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
    };
}

@if ((bool)(ViewBag.PushEnabled ?? false))
{
    <div class="m-card" id="pushCard" style="margin-bottom:14px;display:none;">
        @Html.AntiForgeryToken()
        <div style="font-weight:700;margin-bottom:4px;">Anlık bildirimler</div>
        <div class="m-row-sub" style="margin-bottom:10px;">Uygulama kapalıyken de talep atamalarından haberdar olun.</div>
        <button type="button" id="pushToggleBtn" style="width:100%;height:44px;background:var(--m-primary);color:#fff;border:none;border-radius:12px;font-weight:700;">
            Anlık bildirimleri aç
        </button>
        <div id="pushStatus" class="m-row-sub" style="margin-top:8px;"></div>
    </div>
    <script src="~/js/mobile-push.js" data-public-key="@ViewBag.PushPublicKey" asp-append-version="true"></script>
}

@if (unreadCount > 0)
{
    <form method="post" asp-area="Mobile" asp-controller="Bildirimler" asp-action="TumunuOku" style="margin-bottom:14px;">
        @Html.AntiForgeryToken()
        <button type="submit" style="width:100%;height:44px;background:var(--m-surface);border:1px solid var(--m-border);color:var(--m-primary);border-radius:12px;font-weight:700;">
            Tümünü okundu işaretle (@unreadCount)
        </button>
    </form>
}

@if (Model.Count == 0)
{
    <div class="m-empty">
        <div class="m-empty-icon">
            <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></svg>
        </div>
        <div>Bildiriminiz yok.</div>
    </div>
}
else
{
    <div class="m-list">
        @foreach (var n in Model)
        {
            <a class="m-list-item" style="align-items:flex-start;@(n.IsRead ? "" : "background:#eff6ff;")"
               asp-area="Mobile" asp-controller="Bildirimler" asp-action="Ac" asp-route-id="@n.Id">
                <span style="flex:none;width:36px;height:36px;border-radius:999px;background:@(n.IsRead ? "#f1f5f9" : "#dbeafe");color:@(n.IsRead ? "var(--m-muted)" : "var(--m-primary)");display:flex;align-items:center;justify-content:center;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="@TypeIcon(n.Type)" /></svg>
                </span>
                <div class="m-li-main">
                    <div class="m-li-title" style="font-weight:@(n.IsRead ? "600" : "800");">@n.Title</div>
                    @if (!string.IsNullOrWhiteSpace(n.Body))
                    {
                        <div class="m-li-sub" style="white-space:normal;">@n.Body</div>
                    }
                    <div class="m-li-sub">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                @if (!n.IsRead)
                {
                    <span style="flex:none;width:9px;height:9px;border-radius:999px;background:var(--m-primary);margin-top:6px;"></span>
                }
            </a>
        }
    </div>
}
