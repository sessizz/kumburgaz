@{
    ViewData["Title"] = "Gösterge Paneli";

    var totalDebt = ViewBag.TotalDebt is decimal debt ? debt : 0m;
    var totalGenerated = ViewBag.TotalGenerated is decimal generated ? generated : 0m;
    var totalCollections = ViewBag.TotalCollections is decimal collections ? collections : 0m;
    var billingGroups = ViewBag.BillingGroups is int groups ? groups : 0;
    var activeUnits = ViewBag.ActiveUnits is int units ? units : 0;
    var combinedUnits = ViewBag.CombinedUnits is int combined ? combined : 0;
    var openInstallments = ViewBag.OpenInstallments is int open ? open : 0;
    var paidInstallments = ViewBag.PaidInstallments is int paid ? paid : 0;
    var ledgerIncome = ViewBag.LedgerIncome is decimal income ? income : 0m;
    var ledgerExpense = ViewBag.LedgerExpense is decimal expense ? expense : 0m;
    var netBalance = totalCollections + ledgerIncome - totalDebt - ledgerExpense;
    var collectionRate = totalGenerated > 0 ? Math.Min(100m, Math.Round(totalCollections / totalGenerated * 100m, 0)) : 0m;
    var debtRate = totalGenerated > 0 ? Math.Min(100m, Math.Round(totalDebt / totalGenerated * 100m, 0)) : 0m;
    var installmentCount = openInstallments + paidInstallments;
    var paidRate = installmentCount > 0 ? Math.Round((decimal)paidInstallments / installmentCount * 100m, 0) : 0m;
    var statusText = totalDebt <= 0 ? "Borç yok" : collectionRate >= 70 ? "Takipte" : "Tahsilat gerekli";
    var statusBadge = totalDebt <= 0 ? "badge-success" : collectionRate >= 70 ? "badge-warning" : "badge-error";
}

<div class="space-y-6">
    <section class="card bg-base-100 shadow-sm border border-base-300 overflow-hidden">
        <div class="grid grid-cols-1 xl:grid-cols-[1.35fr_0.65fr]">
            <div class="p-6 lg:p-8">
                <div class="flex flex-wrap items-center gap-3 mb-5">
                    <span class="badge @statusBadge badge-soft gap-1">
                        <span class="material-symbols-outlined ms-sm">monitoring</span>
                        @statusText
                    </span>
                    <span class="text-xs font-medium text-base-content/60">@DateTime.Today.ToString("dd.MM.yyyy") güncel görünüm</span>
                </div>

                <h1 class="text-2xl lg:text-3xl font-extrabold tracking-tight">Kumburgaz Sitesi finansal özeti</h1>
                <p class="mt-2 text-sm lg:text-base text-base-content/70">Tahsilat, açık borç ve dönem üretimi tek ekranda takip edilir.</p>

                <div class="mt-6 flex flex-wrap gap-3">
                    <a class="btn btn-primary" asp-controller="Ledger" asp-action="Create">
                        <span class="material-symbols-outlined ms-md">add</span>
                        Gelir/Gider Gir
                    </a>
                    <a class="btn btn-outline" asp-controller="DuesGeneration" asp-action="Index">
                        <span class="material-symbols-outlined ms-md">event_repeat</span>
                        Dönem Üret
                    </a>
                    <a class="btn btn-outline" asp-controller="Reports" asp-action="DuesDebt">
                        <span class="material-symbols-outlined ms-md">description</span>
                        Borç Raporu
                    </a>
                </div>
            </div>

            <div class="bg-base-200/60 border-t xl:border-l xl:border-t-0 border-base-300 p-6 lg:p-8">
                <p class="text-sm font-medium text-base-content/60">Net pozisyon</p>
                <p class="mt-2 text-3xl font-extrabold tracking-tight @(netBalance >= 0 ? "text-success" : "text-error")">
                    @netBalance.ToString("N0") <span class="text-base font-semibold">TL</span>
                </p>

                <div class="mt-6 space-y-4">
                    <div>
                        <div class="flex items-center justify-between text-xs font-semibold text-base-content/70">
                            <span>Tahsilat oranı</span>
                            <span>@collectionRate.ToString("N0")%</span>
                        </div>
                        <progress class="progress progress-primary mt-2 w-full" value="@collectionRate" max="100"></progress>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-xs font-semibold text-base-content/70">
                            <span>Açık borç oranı</span>
                            <span>@debtRate.ToString("N0")%</span>
                        </div>
                        <progress class="progress progress-error mt-2 w-full" value="@debtRate" max="100"></progress>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-5">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-sm text-base-content/60">Toplam Tahsilat</p>
                        <p class="mt-2 text-2xl font-extrabold">@totalCollections.ToString("N0") TL</p>
                    </div>
                    <span class="material-symbols-outlined rounded-xl bg-success/10 p-2 text-success">payments</span>
                </div>
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-5">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-sm text-base-content/60">Kalan Borç</p>
                        <p class="mt-2 text-2xl font-extrabold">@totalDebt.ToString("N0") TL</p>
                    </div>
                    <span class="material-symbols-outlined rounded-xl bg-error/10 p-2 text-error">priority_high</span>
                </div>
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-5">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-sm text-base-content/60">Üretilen Aidat</p>
                        <p class="mt-2 text-2xl font-extrabold">@totalGenerated.ToString("N0") TL</p>
                    </div>
                    <span class="material-symbols-outlined rounded-xl bg-info/10 p-2 text-info">receipt_long</span>
                </div>
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body p-5">
                <div class="flex items-start justify-between gap-3">
                    <div>
                        <p class="text-sm text-base-content/60">Aktif Daire</p>
                        <p class="mt-2 text-2xl font-extrabold">@activeUnits</p>
                        <p class="mt-1 text-xs text-base-content/60">@combinedUnits birleşik daire</p>
                    </div>
                    <span class="material-symbols-outlined rounded-xl bg-secondary/10 p-2 text-secondary">apartment</span>
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body">
                <div class="flex items-center justify-between">
                    <div>
                        <h2 class="card-title text-base">Tahakkuk durumu</h2>
                        <p class="text-sm text-base-content/60">Borç kayıtlarının ödeme görünümü</p>
                    </div>
                    <span class="text-sm font-bold">@paidRate.ToString("N0")%</span>
                </div>

                <progress class="progress progress-success w-full" value="@paidRate" max="100"></progress>

                <div class="grid grid-cols-2 gap-3 mt-2">
                    <div class="stat bg-base-200/60 rounded-box p-4">
                        <div class="stat-title text-xs">Ödenen kayıt</div>
                        <div class="stat-value text-2xl">@paidInstallments</div>
                    </div>
                    <div class="stat bg-base-200/60 rounded-box p-4">
                        <div class="stat-title text-xs">Açık kayıt</div>
                        <div class="stat-value text-2xl">@openInstallments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm border border-base-300">
            <div class="card-body">
                <div class="flex items-center justify-between mb-2">
                    <div>
                        <h2 class="card-title text-base">Hızlı erişim</h2>
                        <p class="text-sm text-base-content/60">Sık kullanılan işlemler</p>
                    </div>
                    <span class="material-symbols-outlined rounded-xl bg-base-200 p-2">bolt</span>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <a class="btn btn-outline justify-start gap-3" asp-controller="Units" asp-action="Index">
                        <span class="material-symbols-outlined ms-md">group</span>
                        <span>Daireler</span>
                    </a>
                    <a class="btn btn-outline justify-start gap-3" asp-controller="BillingGroups" asp-action="Index">
                        <span class="material-symbols-outlined ms-md">view_list</span>
                        <span>Aidat Grupları</span>
                    </a>
                    <a class="btn btn-outline justify-start gap-3" asp-controller="Ledger" asp-action="Index">
                        <span class="material-symbols-outlined ms-md">account_balance_wallet</span>
                        <span>Giderler</span>
                    </a>
                    <a class="btn btn-outline justify-start gap-3" asp-controller="Reports" asp-action="DuesDebt">
                        <span class="material-symbols-outlined ms-md">download</span>
                        <span>Raporlar</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>
