@model Kumburgaz.Web.Models.CashBankDetailViewModel
@using System.Globalization
@{
    var trTR = new CultureInfo("tr-TR");
    var balStr = Model.Balance.ToString("N2", trTR);
    var dotIdx = balStr.LastIndexOf(',');
    var balMain = dotIdx >= 0 ? balStr[..dotIdx] : balStr;
    var balCents = dotIdx >= 0 ? balStr[(dotIdx + 1)..] : "00";
}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm">
    <div class="p-4 border-b border-gray-100 flex items-center gap-2">
        <div class="dropdown">
            <button tabindex="0" class="btn btn-sm btn-outline">
                Diğer
                <span class="material-symbols-outlined ms-sm">expand_more</span>
            </button>
            <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-10 w-40 p-2 shadow-sm border border-gray-200">
                <li><button type="button" onclick="accountEditModal.showModal()">Düzenle</button></li>
                <li>
                    <form asp-action="SetActive" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="kind" value="@Model.Kind" />
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="active" value="@(Model.IsActive ? "false" : "true")" />
                        <input type="hidden" name="command" value="@(Model.IsActive ? "deactivate" : "activate")" />
                        <button type="submit">@(Model.IsActive ? "Pasifleştir" : "Aktifleştir")</button>
                    </form>
                </li>
                <li><button type="button" class="text-error" onclick="accountDeleteModal.showModal()">Sil</button></li>
            </ul>
        </div>
        <div class="flex-1"></div>
        <div class="dropdown dropdown-end">
            <button tabindex="0" class="btn btn-sm btn-primary">
                <span class="material-symbols-outlined ms-sm">swap_horiz</span>
                Para Hareketi
            </button>
            <ul tabindex="0" class="dropdown-content menu bg-base-100 rounded-box z-10 w-52 p-2 shadow-sm border border-gray-200">
                <li><button type="button" onclick="incomeModal.showModal()">Gelir</button></li>
                <li><button type="button" onclick="openLedgerModal(false)">Ödeme</button></li>
                @if (Model.Kind == "bank")
                {
                    <li><button type="button" onclick="openLedgerModal(true)">Banka Masrafı</button></li>
                }
                <li><button type="button" onclick="transferModal.showModal()">Para Transferi</button></li>
            </ul>
        </div>
        <button type="button" class="btn btn-sm btn-outline" onclick="importModal.showModal()">
            <span class="material-symbols-outlined ms-sm">upload_file</span>
            Import
        </button>
    </div>
    <div class="p-5">
        <div class="text-xs font-semibold tracking-widest uppercase text-gray-400">Bakiye</div>
        <div class="mt-1 flex items-baseline gap-1">
            <span class="text-3xl font-extrabold text-gray-900 tabular-nums">@balMain,<span class="text-gray-500 text-2xl">@balCents</span></span>
            <span class="text-base text-gray-500 ml-1">₺</span>
        </div>
        @if (Model.LastTransactionAt.HasValue)
        {
            <div class="text-xs text-gray-400 mt-1">Son işlem @Model.LastTransactionAt.Value.ToString("d MMM yyyy", new CultureInfo("tr-TR"))</div>
        }
        <div class="grid grid-cols-3 gap-2 mt-4">
            @{
                var shortcuts = Model.Kind == "bank"
                    ? new[] { ("south_west", "Gelir"), ("north_east", "Ödeme"), ("swap_horiz", "Transfer") }
                    : new[] { ("south_west", "Gelir"), ("north_east", "Ödeme"), ("upload", "Bankaya Yatır") };
            }
            @foreach (var (icon, label) in shortcuts)
            {
                var click = label == "Gelir"
                    ? "incomeModal.showModal()"
                    : label == "Ödeme"
                        ? "openLedgerModal(false)"
                        : "transferModal.showModal()";
                <button type="button" onclick="@click" class="flex flex-col items-center gap-1 py-2.5 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50/40 text-gray-700 hover:text-blue-700 transition">
                    <span class="material-symbols-outlined">@icon</span>
                    <span class="text-xs font-medium">@label</span>
                </button>
            }
        </div>
    </div>
</div>

<dialog id="accountEditModal" class="modal">
    <div class="modal-box">
        <form asp-action="UpdateAccount" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Kind" value="@Model.Kind" />
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold">Hesabı Düzenle</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="accountEditModal.close()">✕</button>
            </div>
            <fieldset class="fieldset">
                <legend class="fieldset-legend">Ad</legend>
                <input name="Name" value="@Model.Name" class="input input-bordered w-full" required />
            </fieldset>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Açılış Bakiyesi</legend>
                    <input name="OpeningBalance" type="text" inputmode="decimal" value="@Model.OpeningBalance.ToString("0.##", trTR)" class="input input-bordered w-full" required />
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Açılış Tarihi</legend>
                    <input name="OpeningBalanceDate" type="date" value="@Model.OpeningDate.ToString("yyyy-MM-dd")" class="input input-bordered w-full" required />
                </fieldset>
            </div>
            @if (Model.Kind == "bank")
            {
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Şube</legend>
                    <input name="Branch" value="@Model.Branch" class="input input-bordered w-full" />
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">IBAN</legend>
                    <input name="Iban" value="@Model.Iban" class="input input-bordered w-full" />
                </fieldset>
            }
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="accountEditModal.close()">Vazgeç</button>
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>kapat</button></form>
</dialog>

<dialog id="accountDeleteModal" class="modal">
    <div class="modal-box">
        <form asp-action="DeleteAccount" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="kind" value="@Model.Kind" />
            <input type="hidden" name="id" value="@Model.Id" />
            <h3 class="text-lg font-bold">Hesabı Sil</h3>
            <p class="text-sm text-gray-500">İşlem görmüş hesaplar silinemez; bu durumda pasifleştirme kullanılır.</p>
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="accountDeleteModal.close()">Vazgeç</button>
                <button type="submit" class="btn btn-error">Sil</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>kapat</button></form>
</dialog>

<dialog id="importModal" class="modal">
    <div class="modal-box">
        <form asp-action="PreviewImport" method="post" enctype="multipart/form-data" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="kind" value="@Model.Kind" />
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold">CSV Import</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="importModal.close()">✕</button>
            </div>
            <fieldset class="fieldset">
                <legend class="fieldset-legend">CSV dosyası</legend>
                <input name="file" type="file" accept=".csv,text/csv" class="file-input file-input-bordered w-full" required />
            </fieldset>
            <div class="flex items-center justify-between gap-3 text-xs text-gray-500">
                <span>Tanınan başlıklar: tip, tarih, tutar, daire, kişi, kategori, açıklama, referans, not.</span>
                <a class="btn btn-xs btn-outline"
                   asp-action="DownloadImportTemplate"
                   asp-route-kind="@Model.Kind"
                   asp-route-id="@Model.Id">
                    Şablon indir
                </a>
            </div>
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="importModal.close()">Vazgeç</button>
                <button type="submit" class="btn btn-primary">Önizle</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>kapat</button></form>
</dialog>

<dialog id="incomeModal" class="modal">
    <div class="modal-box max-w-2xl">
        <form asp-action="CreateIncome" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Kind" value="@Model.Kind" />
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold">Gelir</h3>
                <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="incomeModal.close()">✕</button>
            </div>
            <fieldset class="fieldset">
                <legend class="fieldset-legend">Gelir kategorisi</legend>
                <select name="IncomeSource"
                        class="select select-bordered w-full"
                        required
                        data-income-source
                        onchange="syncIncomeFields()">
                    <option value="">Seçiniz</option>
                    <option value="dues">Aidat</option>
                    @foreach (var option in Model.IncomeCategoryOptions)
                    {
                        <option value="category:@option.Value">@option.Text</option>
                    }
                </select>
            </fieldset>
            <div class="hidden space-y-4" data-income-dues-fields>
                <input type="hidden" name="BillingGroupId" data-dues-billing-group />
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Dönem</legend>
                    <select class="select select-bordered w-full" data-dues-period>
                        @foreach (var option in Model.PeriodOptions)
                        {
                            <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                        }
                    </select>
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Daire / Malik</legend>
                    <label class="input input-bordered flex items-center gap-2 mb-2">
                        <span class="material-symbols-outlined ms-sm text-gray-400">search</span>
                        <input type="search" data-dues-search placeholder="Daire no, blok veya isim ara" class="grow" />
                    </label>
                    <select name="DuesInstallmentId" class="select select-bordered w-full" data-dues-select>
                        <option value="">Daire veya malik seçin</option>
                        @foreach (var option in Model.DuesInstallmentOptions)
                        {
                            <option value="@option.Id"
                                    data-billing-group-id="@option.BillingGroupId"
                                    data-amount="@option.RemainingAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                    data-period="@option.Period"
                                    data-search="@option.SearchText">@option.Text</option>
                        }
                    </select>
                </fieldset>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Tarih</legend>
                    <input name="Date" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="input input-bordered w-full" required />
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Tutar</legend>
                    <input name="Amount" type="text" inputmode="decimal" class="input input-bordered w-full" required data-dues-amount />
                </fieldset>
            </div>
            <fieldset class="fieldset hidden" data-income-ledger-fields>
                <legend class="fieldset-legend">Açıklama</legend>
                <textarea name="Description"
                          class="textarea textarea-bordered w-full"
                          rows="2"
                          placeholder="Gelir açıklaması"></textarea>
            </fieldset>
            <div class="hidden space-y-4" data-income-dues-fields>
                <fieldset class="fieldset">
                    <label class="label cursor-pointer gap-2 px-0 w-fit">
                        <input type="checkbox" id="createCollectionIsReceipt" name="IsReceipt" value="true" class="toggle toggle-sm toggle-primary" />
                        <span class="label-text">Makbuz</span>
                    </label>
                </fieldset>
                <fieldset class="fieldset">
                    <legend id="createCollectionReferenceNoLegend" class="fieldset-legend">Referans / Not</legend>
                    <input name="ReferenceNo" id="createCollectionReferenceNo" class="input input-bordered w-full mb-2" placeholder="Referans no" />
                    <textarea name="Note" class="textarea textarea-bordered w-full" rows="2" placeholder="Not"></textarea>
                </fieldset>
            </div>
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="incomeModal.close()">Vazgeç</button>
                <button type="submit" class="btn btn-primary">Kaydet</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>kapat</button></form>
</dialog>

