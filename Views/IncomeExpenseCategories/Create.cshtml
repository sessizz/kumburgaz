@model Kumburgaz.Web.Models.IncomeExpenseCategory
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Yeni Kategori";
}

<div class="max-w-xl mx-auto space-y-4">
    <div class="flex items-center gap-3">
        <a class="btn btn-ghost btn-sm btn-square" asp-action="Index" title="Geri">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h2 class="text-2xl font-extrabold">Yeni Kategori</h2>
    </div>

    <div class="card bg-base-100 shadow-sm border border-base-300">
        <div class="card-body">
            <form asp-action="Create" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="alert alert-error text-sm py-2"></div>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Tür</legend>
                    <select asp-for="Type" asp-items="(IEnumerable<SelectListItem>)ViewBag.Types" class="select select-bordered w-full"></select>
                    <span asp-validation-for="Type" class="text-error text-xs"></span>
                </fieldset>
                <fieldset class="fieldset">
                    <legend class="fieldset-legend">Ad</legend>
                    <input asp-for="Name" class="input input-bordered w-full" />
                    <span asp-validation-for="Name" class="text-error text-xs"></span>
                </fieldset>
                <label class="label cursor-pointer justify-start gap-3">
                    <input asp-for="Active" class="toggle toggle-primary" />
                    <span class="label-text">Aktif</span>
                </label>
                <div class="flex gap-2 justify-end pt-2">
                    <a class="btn btn-ghost" asp-action="Index">Vazgeç</a>
                    <button class="btn btn-primary" type="submit">
                        <span class="material-symbols-outlined ms-sm">save</span>
                        Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
