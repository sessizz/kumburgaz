@using Kumburgaz.Web.Services
@inject PushSenderService PushSender
@{
    var title = ViewData["Title"]?.ToString() ?? "Kumburgaz";
    var backUrl = ViewData["MobileBack"]?.ToString();
}
<!DOCTYPE html>
<html lang="tr" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover" />
    <title>@title - Kumburgaz</title>

    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="icon" type="image/png" href="/img/icons/favicon-32.png" />

    <!-- iOS ana ekran destegi -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Kumburgaz" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
</head>
<body>
    <div class="m-app">
        <header class="m-topbar">
            @if (!string.IsNullOrEmpty(backUrl))
            {
                <a class="m-iconbtn m-back" href="@backUrl" aria-label="Geri">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
                </a>
            }
            <span class="m-title">@title</span>
            <a class="m-iconbtn" id="bellIcon" aria-label="Bildirimler" title="Bildirimler"
               asp-area="Mobile" asp-controller="Bildirimler" asp-action="Index">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></svg>
                <span id="bellBadge" class="m-badge-count" style="display:none;">0</span>
            </a>
        </header>

        <main class="m-main">
            @RenderBody()
        </main>

        <partial name="_BottomNav" />
    </div>

    @* Paylasilan fotograf lightbox'i: herhangi bir sayfa openLightbox(url) cagirarak
       fotografi indirmek/yeni sekme acmak yerine ayni sayfada buyuk gosterir. *@
    <dialog id="photoLightbox" class="m-lightbox" onclick="if (event.target === this) closeLightbox()">
        <button type="button" class="m-lightbox-close" onclick="closeLightbox()" aria-label="Kapat">✕</button>
        <img id="photoLightboxImg" src="" alt="Fotoğraf" />
    </dialog>
    <script>
        function openLightbox(url) {
            document.getElementById('photoLightboxImg').src = url;
            document.getElementById('photoLightbox').showModal();
        }
        function closeLightbox() {
            document.getElementById('photoLightbox').close();
            document.getElementById('photoLightboxImg').src = '';
        }
    </script>

    @if (PushSender.Enabled)
    {
        @Html.AntiForgeryToken()
        @* Ilk mobil girişte (localStorage'da daha once sorulmadiysa) bildirim izni ister.
           Gercek tarayici izin istemi yalnizca "Bildirimleri Aç" tiklamasinda tetiklenir;
           bu dialog kendisi otomatik acilsa da tarayici guvenlik kurali gereği
           Notification.requestPermission() bir kullanici jesti icinde cagrilmak zorunda. *@
        <dialog id="pushPromptDialog" class="m-push-prompt">
            <div class="m-push-prompt-icon">🔔</div>
            <div class="m-push-prompt-title">Bildirimleri açmak ister misiniz?</div>
            <div class="m-push-prompt-body">Talep atamaları ve duyurular için anlık bildirim alın.</div>
            <div class="m-push-prompt-actions">
                <button type="button" id="pushPromptNo">Şimdi değil</button>
                <button type="button" id="pushPromptYes">Bildirimleri Aç</button>
            </div>
        </dialog>
        <script src="~/js/mobile-push.js" data-public-key="@PushSender.PublicKey" asp-append-version="true"></script>
    }

    <script src="~/js/mobile.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
