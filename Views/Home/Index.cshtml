@{
    ViewData["Title"] = "Genel Bakış";

    var totalDebt        = ViewBag.TotalDebt        is decimal d  ? d  : 0m;
    var totalGenerated   = ViewBag.TotalGenerated   is decimal g  ? g  : 0m;
    var totalCollections = ViewBag.TotalCollections is decimal c  ? c  : 0m;
    var activeUnits      = ViewBag.ActiveUnits      is int     u  ? u  : 0;
    var combinedUnits    = ViewBag.CombinedUnits    is int     cu ? cu : 0;
    var openInstallments = ViewBag.OpenInstallments is int     oi ? oi : 0;
    var paidInstallments = ViewBag.PaidInstallments is int     pi ? pi : 0;
    var ledgerIncome     = ViewBag.LedgerIncome     is decimal li ? li : 0m;
    var ledgerExpense    = ViewBag.LedgerExpense    is decimal le ? le : 0m;

    var netBalance   = totalCollections + ledgerIncome - totalDebt - ledgerExpense;
    var installTotal = openInstallments + paidInstallments;
    var paidPct      = installTotal > 0 ? (double)paidInstallments / installTotal * 100 : 0;
    var collPct      = totalGenerated > 0 ? (double)(totalCollections / totalGenerated * 100m) : 0;

    var cashBankItems = ViewBag.CashBankItems as List<Kumburgaz.Web.Models.CashBankListItemViewModel> ?? new();

    @* SVG donut: r=54, sw=14, circumference ≈ 339.3 *@
    const double CIR = 2 * Math.PI * 54;
    double Offset(double pct) => CIR * (1 - Math.Min(pct, 100) / 100);
}

<div class="space-y-4">

    @* Row 1: two donut cards *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

        @* Tahsilat donut *@
        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <h2 class="text-sm font-semibold text-gray-500 mb-4 uppercase tracking-wide">Tahsil Edilecekler</h2>
            <div class="flex items-center gap-8">
                <div class="relative shrink-0">
                    <svg width="140" height="140" viewBox="0 0 140 140">
                        <circle cx="70" cy="70" r="54" fill="none" stroke="#e5e7eb" stroke-width="14" />
                        <circle cx="70" cy="70" r="54" fill="none" stroke="#60a5fa" stroke-width="14"
                                stroke-dasharray="@CIR.ToString("F2")"
                                stroke-dashoffset="@Offset(collPct).ToString("F2")"
                                stroke-linecap="round"
                                transform="rotate(-90 70 70)" />
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-lg font-bold text-gray-900 leading-none">@totalCollections.ToString("N0")</span>
                        <span class="text-xs text-gray-400 mt-1">₺ · @activeUnits Hesap</span>
                    </div>
                </div>
                <div class="space-y-3 text-sm min-w-0">
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-blue-400 shrink-0"></span>
                            <span class="text-gray-500">Tahsilat</span>
                        </div>
                        <div class="ml-5 font-semibold text-gray-900">@totalCollections.ToString("N2") ₺</div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-amber-400 shrink-0"></span>
                            <span class="text-gray-500">Vadesi Gelmemiş</span>
                        </div>
                        <div class="ml-5 font-semibold text-gray-900">@(Math.Max(0m, totalGenerated - totalCollections - totalDebt).ToString("N2")) ₺</div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-red-400 shrink-0"></span>
                            <span class="text-gray-500">Geciken</span>
                        </div>
                        <div class="ml-5 font-semibold text-gray-900">@totalDebt.ToString("N2") ₺</div>
                    </div>
                </div>
            </div>
        </div>

        @* Taksit donut *@
        <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <h2 class="text-sm font-semibold text-gray-500 mb-4 uppercase tracking-wide">Taksit Durumu</h2>
            <div class="flex items-center gap-8">
                <div class="relative shrink-0">
                    <svg width="140" height="140" viewBox="0 0 140 140">
                        <circle cx="70" cy="70" r="54" fill="none" stroke="#e5e7eb" stroke-width="14" />
                        <circle cx="70" cy="70" r="54" fill="none" stroke="#f87171" stroke-width="14"
                                stroke-dasharray="@CIR.ToString("F2")"
                                stroke-dashoffset="@Offset(paidPct).ToString("F2")"
                                stroke-linecap="round"
                                transform="rotate(-90 70 70)" />
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-lg font-bold text-gray-900 leading-none">@paidPct.ToString("N0")%</span>
                        <span class="text-xs text-gray-400 mt-1">ödendi</span>
                    </div>
                </div>
                <div class="space-y-3 text-sm min-w-0">
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-red-400 shrink-0"></span>
                            <span class="text-gray-500">Ödendi</span>
                        </div>
                        <div class="ml-5 font-semibold text-gray-900">@paidInstallments kayıt</div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-gray-200 shrink-0"></span>
                            <span class="text-gray-500">Açık</span>
                        </div>
                        <div class="ml-5 font-semibold text-gray-900">@openInstallments kayıt</div>
                    </div>
                    <div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-sm bg-emerald-400 shrink-0"></span>
                            <span class="text-gray-500">Net Pozisyon</span>
                        </div>
                        <div class="ml-5 font-semibold @(netBalance >= 0 ? "text-emerald-600" : "text-red-600")">
                            @netBalance.ToString("N2") ₺
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Row 2: 4 metric tiles *@
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <a asp-controller="Units" asp-action="Index"
           class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex items-center justify-between hover:border-purple-300 hover:shadow-md transition-all group">
            <div>
                <div class="text-xs font-medium text-gray-400">Aktif Daire</div>
                <div class="text-2xl font-bold text-gray-900 mt-1">@activeUnits</div>
                <div class="text-xs text-gray-400 mt-0.5">@combinedUnits birleşik</div>
            </div>
            <span class="material-symbols-outlined text-purple-300 group-hover:text-purple-500 transition-colors" style="font-size:30px">group</span>
        </a>

        <a asp-controller="DuesGeneration" asp-action="Index"
           class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex items-center justify-between hover:border-indigo-300 hover:shadow-md transition-all group">
            <div>
                <div class="text-xs font-medium text-gray-400">Üretilen Aidat</div>
                <div class="text-base font-bold text-gray-900 mt-1 leading-tight">@totalGenerated.ToString("N0") ₺</div>
                <div class="text-xs text-gray-400 mt-0.5">dönem toplam</div>
            </div>
            <span class="material-symbols-outlined text-indigo-300 group-hover:text-indigo-500 transition-colors" style="font-size:30px">event_repeat</span>
        </a>

        <a asp-controller="Ledger" asp-action="Create"
           class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex items-center justify-between hover:border-amber-300 hover:shadow-md transition-all group">
            <div>
                <div class="text-xs font-medium text-gray-400">Giderler</div>
                <div class="text-base font-bold text-gray-900 mt-1 leading-tight">@ledgerExpense.ToString("N0") ₺</div>
                <div class="text-xs text-emerald-500 mt-0.5">Gelir: @ledgerIncome.ToString("N0") ₺</div>
            </div>
            <span class="material-symbols-outlined text-amber-300 group-hover:text-amber-500 transition-colors" style="font-size:30px">payments</span>
        </a>

        <a asp-controller="Reports" asp-action="DuesDebt"
           class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm flex items-center justify-between hover:border-pink-300 hover:shadow-md transition-all group">
            <div>
                <div class="text-xs font-medium text-gray-400">Kalan Borç</div>
                <div class="text-base font-bold @(totalDebt > 0 ? "text-red-600" : "text-emerald-600") mt-1 leading-tight">@totalDebt.ToString("N0") ₺</div>
                <div class="text-xs text-gray-400 mt-0.5">borç raporu</div>
            </div>
            <span class="material-symbols-outlined text-pink-300 group-hover:text-pink-500 transition-colors" style="font-size:30px">bar_chart</span>
        </a>
    </div>

    @* Row 3: Kasa/Banka + Hızlı İşlemler *@
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                <h2 class="font-semibold text-gray-800 text-sm">Kasa ve Bankalar</h2>
                <a asp-controller="CashBank" asp-action="Index" class="text-xs text-blue-600 hover:underline font-medium">Tümü →</a>
            </div>
            @if (cashBankItems.Any())
            {
                <ul class="divide-y divide-gray-100">
                    @foreach (var item in cashBankItems)
                    {
                        <li class="flex items-center justify-between px-5 py-3">
                            <div class="flex items-center gap-2">
                                @if (item.Type == "cash")
                                {
                                    <span class="material-symbols-outlined text-amber-400" style="font-size:18px">payments</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-blue-400" style="font-size:18px">account_balance</span>
                                }
                                <a asp-controller="CashBank" asp-action="Index" class="text-sm text-blue-600 hover:underline">@item.Name</a>
                            </div>
                            <span class="text-sm font-semibold @(item.Balance >= 0 ? "text-gray-800" : "text-red-600")">
                                @item.Balance.ToString("N2") ₺
                            </span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="px-5 py-4 text-sm text-gray-400">
                    <a asp-controller="CashBank" asp-action="Index" class="text-blue-600 hover:underline">Kasa/Banka ekleyin →</a>
                </div>
            }
        </div>

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100">
                <h2 class="font-semibold text-gray-800 text-sm">Hızlı İşlemler</h2>
            </div>
            <div class="p-4 grid grid-cols-2 gap-3">
                <a class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-colors group"
                   asp-controller="Collections" asp-action="Create">
                    <span class="material-symbols-outlined text-blue-400 group-hover:text-blue-600" style="font-size:22px">add_card</span>
                    <span class="text-sm font-medium text-gray-700">Tahsilat Ekle</span>
                </a>
                <a class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-amber-300 hover:bg-amber-50 transition-colors group"
                   asp-controller="Ledger" asp-action="Create">
                    <span class="material-symbols-outlined text-amber-400 group-hover:text-amber-600" style="font-size:22px">receipt</span>
                    <span class="text-sm font-medium text-gray-700">Gider Gir</span>
                </a>
                <a class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition-colors group"
                   asp-controller="DuesGeneration" asp-action="Index">
                    <span class="material-symbols-outlined text-indigo-400 group-hover:text-indigo-600" style="font-size:22px">event_repeat</span>
                    <span class="text-sm font-medium text-gray-700">Dönem Üret</span>
                </a>
                <a class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:border-pink-300 hover:bg-pink-50 transition-colors group"
                   asp-controller="Reports" asp-action="DuesDebt">
                    <span class="material-symbols-outlined text-pink-400 group-hover:text-pink-600" style="font-size:22px">description</span>
                    <span class="text-sm font-medium text-gray-700">Borç Raporu</span>
                </a>
            </div>
        </div>
    </div>

</div>
