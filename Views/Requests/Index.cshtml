@model List<Kumburgaz.Web.Models.ServiceRequest>
@using Kumburgaz.Web.Services
@{
    ViewData["Title"] = "Talepler";
}
<div class="space-y-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <div><h1 class="text-2xl font-extrabold text-gray-900">Talepler</h1><p class="text-sm text-gray-400">Arıza, bakım ve sakin talepleri</p></div>
        <a class="btn btn-primary btn-sm" asp-action="Create"><span class="material-symbols-outlined ms-sm">add</span>Yeni Talep</a>
    </div>
    @if (TempData["ActionSuccess"] is string success) { <div class="alert alert-success"><span class="material-symbols-outlined">check_circle</span><span>@success</span></div> }
    @if (TempData["ActionError"] is string error) { <div class="alert alert-error"><span class="material-symbols-outlined">error</span><span>@error</span></div> }
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <table class="table table-zebra">
            <thead><tr><th>Talep</th><th>Daire</th><th>Öncelik</th><th>Durum</th><th>Atanan</th><th>Tarih</th><th class="text-end">İşlem</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><div class="font-semibold">@item.Title</div><div class="text-xs text-gray-500 line-clamp-1">@item.Description</div></td>
                    <td>@(item.Unit is null ? "Ortak Alan" : UnitDisplayHelper.Display(item.Unit))</td>
                    <td><span class="pill @(item.Priority == ServiceRequestPriority.Urgent ? "pill-neg" : item.Priority == ServiceRequestPriority.High ? "pill-warn" : "pill-info")">@EnumDisplayHelper.Display(item.Priority)</span></td>
                    <td><span class="pill @(item.Status == ServiceRequestStatus.Closed ? "pill-muted" : item.Status == ServiceRequestStatus.Resolved ? "pill-ok" : "pill-info")">@EnumDisplayHelper.Display(item.Status)</span></td>
                    <td>@(item.AssignedTo ?? "—")</td>
                    <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                    <td><div class="flex justify-end gap-1"><a class="btn btn-xs btn-ghost" asp-action="Edit" asp-route-id="@item.Id"><span class="material-symbols-outlined ms-sm">edit</span></a><form method="post" asp-action="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Bu talep silinsin mi?');">@Html.AntiForgeryToken()<button class="btn btn-xs btn-ghost text-error"><span class="material-symbols-outlined ms-sm">delete</span></button></form></div></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
