@model List<SystemUserIndexRowViewModel>
@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="flex items-start justify-between gap-4 mb-6">
    <div>
        <h1 class="text-2xl font-extrabold text-gray-900">Kullanıcılar</h1>
        <p class="text-sm text-gray-400">Giriş hesapları, roller ve malik/personel bağlantıları</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">
        <span class="material-symbols-outlined" style="font-size:18px">add</span>
        Yeni Kullanıcı
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="table w-full">
        <thead>
        <tr>
            <th>E-posta</th>
            <th>Ad</th>
            <th>Bağlı Hesap</th>
            <th>Roller</th>
            <th>Durum</th>
            <th class="text-right">İşlem</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-gray-400 py-8">Kullanıcı yok.</td></tr>
        }
        @foreach (var user in Model)
        {
            <tr>
                <td class="font-semibold">@user.Email</td>
                <td>
                    <div>@(user.FullName ?? "-")</div>
                    @if (!string.IsNullOrWhiteSpace(user.Title))
                    {
                        <div class="text-xs text-gray-400">@user.Title</div>
                    }
                </td>
                <td>@(user.AccountName ?? "-")</td>
                <td>@user.RolesText</td>
                <td>
                    <span class="badge @(user.IsLockedOut ? "badge-error" : "badge-success")">
                        @(user.IsLockedOut ? "Kilitli" : "Aktif")
                    </span>
                </td>
                <td class="text-right">
                    <a class="btn btn-sm btn-outline" asp-action="Edit" asp-route-id="@user.Id">
                        <span class="material-symbols-outlined" style="font-size:16px">edit</span>
                        Düzenle
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
