@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Authenticator Uygulaması Ekle";
}

<div class="max-w-6xl mx-auto space-y-6">
    <div class="flex items-center gap-2 text-sm text-gray-500">
        <a href="/" class="hover:text-gray-700">Ana Sayfa</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Hesabımı Yönet</span>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <a asp-area="Identity" asp-page="/Account/Manage/TwoFactorAuthentication" class="hover:text-gray-700">İki Adımlı Doğrulama</a>
        <span class="material-symbols-outlined" style="font-size:14px">chevron_right</span>
        <span class="text-gray-900 font-medium">Authenticator Ekle</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6">
        <partial name="_ManageNav" />

        <div class="space-y-6">
            <partial name="_StatusMessage" model="Model.StatusMessage" />

            <div class="bg-white border border-gray-200 rounded-xl p-6">
                <div class="mb-6">
                    <h1 class="text-lg font-semibold text-gray-900">Authenticator Uygulaması Ekle</h1>
                    <p class="text-sm text-gray-500 mt-0.5">Google Authenticator veya Authy uygulamasını kullanın</p>
                </div>

                <div class="space-y-6">
                    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
                        <p class="text-sm font-medium text-gray-700 mb-2">Manuel Anahtar</p>
                        <p class="text-xs text-gray-500 mb-3">Uygulamanıza QR kod yerine bu anahtarı manuel olarak girebilirsiniz:</p>
                        <code class="block bg-white border border-gray-200 rounded-lg px-4 py-3 text-sm font-mono tracking-widest text-blue-700 text-center select-all">
                            @Model.SharedKey
                        </code>
                    </div>

                    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
                        <p class="text-sm font-medium text-amber-800 mb-2">
                            <span class="material-symbols-outlined" style="font-size:16px;vertical-align:middle">info</span>
                            Authenticator URI
                        </p>
                        <p class="text-xs text-gray-600 break-all font-mono">@Model.AuthenticatorUri</p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm mb-4"></div>

                        <div class="form-control">
                            <label asp-for="Input.Code" class="label">
                                <span class="label-text font-medium text-gray-700">6 Haneli Doğrulama Kodu</span>
                            </label>
                            <input asp-for="Input.Code" type="text" inputmode="numeric" maxlength="6"
                                   class="input input-bordered w-full text-center tracking-widest font-semibold text-lg"
                                   placeholder="000000" autocomplete="one-time-code" />
                            <span asp-validation-for="Input.Code" class="label-text-alt text-red-500 mt-1 block"></span>
                        </div>

                        <div class="flex justify-end mt-6">
                            <button type="submit" class="btn btn-primary gap-2">
                                <span class="material-symbols-outlined" style="font-size:18px">verified_user</span>
                                Etkinleştir
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
